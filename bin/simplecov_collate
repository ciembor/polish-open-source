#!/usr/bin/env ruby
# frozen_string_literal: true

require 'simplecov'

resultsets = Dir['coverage/*/.resultset.json']
abort 'No SimpleCov shard resultsets found under coverage/*/.resultset.json' if resultsets.empty?

SimpleCov.collate(resultsets) do
  enable_coverage :line
  track_files 'lib/**/*.rb'
  add_filter '/spec/'
  minimum_coverage 100
end
