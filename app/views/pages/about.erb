<section class="hero about-hero">
  <div class="hero__inner">
    <div>
      <p class="eyebrow"><%= h t('about.hero.eyebrow') %></p>
      <h1>Polish Open Source Rank</h1>
      <p class="lede"><%= h t('about.hero.lede') %></p>
    </div>
  </div>
</section>

<%= erb :"shared/location_notice" %>

<section class="about-section" aria-labelledby="mission-heading">
  <div class="content about-grid about-grid--mission">
    <div>
      <p class="eyebrow"><%= h t('about.mission.eyebrow') %></p>
      <h2 id="mission-heading"><%= h t('about.mission.title') %></h2>
    </div>
    <p class="about-lead">
      <%= h t('about.mission.body') %>
    </p>
  </div>
</section>

<section class="about-section about-section--alt" aria-labelledby="rules-heading">
  <div class="content">
    <p class="eyebrow"><%= h t('about.rules.eyebrow') %></p>
    <h2 id="rules-heading"><%= h t('about.rules.title') %></h2>
    <div class="rules-grid">
      <article class="rule-card">
        <span class="rule-card__number">01</span>
        <h3><%= h t('about.rules.data_scope.title') %></h3>
        <p><%= h t('about.rules.data_scope.body') %></p>
      </article>
      <article class="rule-card">
        <span class="rule-card__number">02</span>
        <h3><%= h t('about.rules.users.title') %></h3>
        <p><%= h t('about.rules.users.body') %></p>
      </article>
      <article class="rule-card">
        <span class="rule-card__number">03</span>
        <h3><%= h t('about.rules.stars.title') %></h3>
        <p><%= h t('about.rules.stars.body') %></p>
      </article>
      <article class="rule-card">
        <span class="rule-card__number">04</span>
        <h3><%= h t('about.rules.trending.title') %></h3>
        <p><%= h t('about.rules.trending.body') %></p>
      </article>
      <article class="rule-card">
        <span class="rule-card__number">05</span>
        <h3><%= h t('about.rules.activity.title') %></h3>
        <p><%= h t('about.rules.activity.body') %></p>
      </article>
      <article class="rule-card">
        <span class="rule-card__number">06</span>
        <h3><%= h t('about.rules.snapshots.title') %></h3>
        <p><%= h t('about.rules.snapshots.body') %></p>
      </article>
    </div>
  </div>
</section>

<section class="about-section" aria-labelledby="platforms-heading">
  <div class="content">
    <p class="eyebrow"><%= h t('about.platforms.eyebrow') %></p>
    <h2 id="platforms-heading"><%= h t('about.platforms.title') %></h2>
    <div class="platform-grid">
      <article class="platform-card platform-card--github">
        <a class="platform-card__link" href="https://github.com/">
          <span class="platform-logo" aria-hidden="true">
            <img class="platform-logo__image" src="<%= h app_path(platform_icon_path("github")) %>" alt="" width="64" height="64">
          </span>
          <span class="platform-card__name">GitHub</span>
        </a>
      </article>
      <article class="platform-card platform-card--gitlab">
        <a class="platform-card__link" href="https://gitlab.com/">
          <span class="platform-logo" aria-hidden="true">
            <img class="platform-logo__image" src="<%= h app_path(platform_icon_path("gitlab")) %>" alt="" width="64" height="64">
          </span>
          <span class="platform-card__name">GitLab</span>
        </a>
      </article>
      <article class="platform-card platform-card--codeberg">
        <a class="platform-card__link" href="https://codeberg.org/">
          <span class="platform-logo" aria-hidden="true">
            <img class="platform-logo__image" src="<%= h app_path(platform_icon_path("codeberg")) %>" alt="" width="64" height="64">
          </span>
          <span class="platform-card__name">Codeberg</span>
        </a>
      </article>
    </div>
  </div>
</section>
