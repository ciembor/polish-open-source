<%
  section_links = [
    ['mission', t('about.section_nav.mission')],
    ['rankings', t('about.section_nav.rankings')],
    ['packages', t('about.section_nav.packages')],
    ['discord', t('about.section_nav.discord')],
    ['badge', t('about.section_nav.badge')],
    ['data-sources', t('about.section_nav.data_sources')],
    ['open-source', t('about.section_nav.open_source')]
  ]
%>

<section class="hero about-hero" id="about-top">
  <div class="hero__inner">
    <div>
      <p class="eyebrow"><%= h t('about.hero.eyebrow') %></p>
      <h1>Polish Open Source</h1>
      <p class="lede"><%= h t('about.hero.lede') %></p>
    </div>

    <% if current_user %>
      <img class="hero__image" src="/images/polish_open_source_front.webp" alt="" aria-hidden="true">
    <% else %>
      <a class="hero__image-link" href="<%= h app_path('/auth/github') %>" aria-label="<%= h t('auth.login.github') %>">
        <img class="hero__image" src="/images/polish_open_source_front.webp" alt="" aria-hidden="true">
      </a>
    <% end %>
  </div>
</section>

<%= erb :"shared/location_notice" %>

<nav class="about-section-nav" aria-label="<%= h t('about.section_nav.label') %>">
  <div class="content">
    <ul class="about-section-nav__list">
      <% section_links.each do |target, label| %>
        <li>
          <a class="about-section-nav__link" href="#<%= h target %>"><%= h label %></a>
        </li>
      <% end %>
    </ul>
  </div>
</nav>

<section class="about-section" id="mission" aria-labelledby="mission-heading">
  <div class="content">
    <div class="about-section__header">
      <div>
        <p class="eyebrow"><%= h t('about.mission.eyebrow') %></p>
        <div class="about-section__title-row">
          <h2 id="mission-heading"><%= h t('about.mission.title') %></h2>
          <a class="about-section__back-link" href="#about-top"><%= h t('about.back_to_top') %></a>
        </div>
      </div>
    </div>
    <div class="about-copy">
      <p class="about-lead"><%= h t('about.mission.body') %></p>
    </div>
  </div>
</section>

<section class="about-section about-section--alt" id="rankings" aria-labelledby="rankings-heading">
  <div class="content">
    <div class="about-section__header">
      <div>
        <p class="eyebrow"><%= h t('about.rankings.eyebrow') %></p>
        <div class="about-section__title-row">
          <h2 id="rankings-heading"><%= h t('about.rankings.title') %></h2>
          <a class="about-section__back-link" href="#about-top"><%= h t('about.back_to_top') %></a>
        </div>
      </div>
    </div>
    <div class="about-copy">
      <section class="about-subsection" aria-labelledby="rankings-data-scope-heading">
        <h3 id="rankings-data-scope-heading"><%= h t('about.rankings.data_scope.title') %></h3>
        <% Array(t('about.rankings.data_scope.paragraphs')).each do |paragraph| %>
          <p><%= h paragraph %></p>
        <% end %>
      </section>
      <section class="about-subsection" aria-labelledby="rankings-eligibility-heading">
        <h3 id="rankings-eligibility-heading"><%= h t('about.rankings.eligibility.title') %></h3>
        <% Array(t('about.rankings.eligibility.paragraphs')).each do |paragraph| %>
          <p><%= h paragraph %></p>
        <% end %>
      </section>
      <section class="about-subsection" aria-labelledby="rankings-metrics-heading">
        <h3 id="rankings-metrics-heading"><%= h t('about.rankings.metrics.title') %></h3>
        <% Array(t('about.rankings.metrics.paragraphs')).each do |paragraph| %>
          <p><%= h paragraph %></p>
        <% end %>
      </section>
      <section class="about-subsection" aria-labelledby="rankings-ordering-heading">
        <h3 id="rankings-ordering-heading"><%= h t('about.rankings.ordering.title') %></h3>
        <% Array(t('about.rankings.ordering.paragraphs')).each do |paragraph| %>
          <p><%= h paragraph %></p>
        <% end %>
      </section>
    </div>
  </div>
</section>

<section class="about-section" id="packages" aria-labelledby="packages-heading">
  <div class="content">
    <div class="about-section__header">
      <div>
        <p class="eyebrow"><%= h t('about.packages.eyebrow') %></p>
        <div class="about-section__title-row">
          <h2 id="packages-heading"><%= h t('about.packages.title') %></h2>
          <a class="about-section__back-link" href="#about-top"><%= h t('about.back_to_top') %></a>
        </div>
      </div>
    </div>
    <div class="about-copy">
      <section class="about-subsection" aria-labelledby="packages-overview-heading">
        <h3 id="packages-overview-heading"><%= h t('about.packages.overview.title') %></h3>
        <% Array(t('about.packages.overview.paragraphs')).each do |paragraph| %>
          <p><%= h paragraph %></p>
        <% end %>
      </section>
      <section class="about-subsection" aria-labelledby="packages-ecosystems-heading">
        <article class="about-note-card">
          <h3 id="packages-ecosystems-heading"><%= h t('about.packages.ecosystems.title') %></h3>
          <p><%= h Array(t('about.packages.ecosystems.items')).join(', ') %>.</p>
        </article>
      </section>
      <section class="about-subsection" aria-labelledby="packages-manifests-heading">
        <article class="about-note-card">
          <h3 id="packages-manifests-heading"><%= h t('about.packages.manifests.title') %></h3>
          <p><%= h Array(t('about.packages.manifests.items')).join(', ') %>.</p>
        </article>
        <p><%= h t('about.packages.manifests.note') %></p>
      </section>
      <section class="about-subsection" aria-labelledby="packages-metrics-heading">
        <h3 id="packages-metrics-heading"><%= h t('about.packages.metrics.title') %></h3>
        <% Array(t('about.packages.metrics.paragraphs')).each do |paragraph| %>
          <p><%= h paragraph %></p>
        <% end %>
        <dl class="about-definition-list">
          <div>
            <dt><%= h t('about.packages.metrics.breakdown.recent_downloads.label') %></dt>
            <dd><%= h t('about.packages.metrics.breakdown.recent_downloads.value') %></dd>
          </div>
          <div>
            <dt><%= h t('about.packages.metrics.breakdown.total_downloads.label') %></dt>
            <dd><%= h t('about.packages.metrics.breakdown.total_downloads.value') %></dd>
          </div>
          <div>
            <dt><%= h t('about.packages.metrics.breakdown.dependents.label') %></dt>
            <dd><%= h t('about.packages.metrics.breakdown.dependents.value') %></dd>
          </div>
        </dl>
      </section>
    </div>
  </div>
</section>

<section class="about-section about-section--alt" id="discord" aria-labelledby="discord-heading">
  <div class="content">
    <div class="about-section__header">
      <div>
        <p class="eyebrow"><%= h t('about.discord.eyebrow') %></p>
        <div class="about-section__title-row">
          <h2 id="discord-heading"><%= h t('about.discord.title') %></h2>
          <a class="about-section__back-link" href="#about-top"><%= h t('about.back_to_top') %></a>
        </div>
      </div>
    </div>
    <div class="about-copy">
      <% Array(t('about.discord.paragraphs')).each do |paragraph| %>
        <p><%= h paragraph %></p>
      <% end %>
    </div>
  </div>
</section>

<section class="about-section" id="badge" aria-labelledby="badge-heading">
  <div class="content">
    <div class="about-section__header">
      <div>
        <p class="eyebrow"><%= h t('about.badge.eyebrow') %></p>
        <div class="about-section__title-row">
          <h2 id="badge-heading"><%= h t('about.badge.title') %></h2>
          <a class="about-section__back-link" href="#about-top"><%= h t('about.back_to_top') %></a>
        </div>
      </div>
    </div>
    <div class="about-copy">
      <% Array(t('about.badge.paragraphs')).each do |paragraph| %>
        <p><%= h paragraph %></p>
      <% end %>
      <section class="about-subsection" aria-labelledby="badge-hierarchy-heading">
        <h3 id="badge-hierarchy-heading"><%= h t('about.badge.hierarchy.title') %></h3>
        <ol class="about-list about-list--ordered">
          <% Array(t('about.badge.hierarchy.items')).each do |item| %>
            <li><%= h item %></li>
          <% end %>
        </ol>
      </section>
    </div>
  </div>
</section>

<section class="about-section about-section--alt" id="data-sources" aria-labelledby="data-sources-heading">
  <div class="content">
    <div class="about-section__header">
      <div>
        <p class="eyebrow"><%= h t('about.data_sources.eyebrow') %></p>
        <div class="about-section__title-row">
          <h2 id="data-sources-heading"><%= h t('about.data_sources.title') %></h2>
          <a class="about-section__back-link" href="#about-top"><%= h t('about.back_to_top') %></a>
        </div>
      </div>
    </div>
    <div class="about-copy">
      <% Array(t('about.data_sources.paragraphs')).each do |paragraph| %>
        <p><%= h paragraph %></p>
      <% end %>
    </div>
  </div>
</section>

<section class="about-section" id="open-source" aria-labelledby="open-source-heading">
  <div class="content">
    <div class="about-section__header">
      <div>
        <p class="eyebrow"><%= h t('about.open_source.eyebrow') %></p>
        <div class="about-section__title-row">
          <h2 id="open-source-heading"><%= h t('about.open_source.title') %></h2>
          <a class="about-section__back-link" href="#about-top"><%= h t('about.back_to_top') %></a>
        </div>
      </div>
    </div>
    <div class="about-copy">
      <% Array(t('about.open_source.paragraphs')).each do |paragraph| %>
        <p><%= h paragraph %></p>
      <% end %>
      <p>
        <a class="about-inline-link" href="https://github.com/ciembor/polish-open-source" target="_blank" rel="noopener noreferrer">
          <%= h t('about.open_source.link_label') %>
        </a>
      </p>
    </div>
  </div>
</section>

<section class="about-section about-section--alt" id="platforms" aria-label="<%= h t('about.platforms.eyebrow') %>">
  <div class="content">
    <p class="eyebrow"><%= h t('about.platforms.eyebrow') %></p>
    <div class="platform-grid">
      <article class="platform-card platform-card--github">
        <a class="platform-card__link" href="https://github.com/">
          <span class="platform-logo" aria-hidden="true">
            <img class="platform-logo__image" src="<%= h app_path(platform_icon_path("github")) %>" alt="" width="64" height="64">
          </span>
          <span class="platform-card__name">GitHub</span>
        </a>
      </article>
      <article class="platform-card platform-card--gitlab">
        <a class="platform-card__link" href="https://gitlab.com/">
          <span class="platform-logo" aria-hidden="true">
            <img class="platform-logo__image" src="<%= h app_path(platform_icon_path("gitlab")) %>" alt="" width="64" height="64">
          </span>
          <span class="platform-card__name">GitLab</span>
        </a>
        <span class="platform-card__best-effort"><%= h t('about.platforms.best_effort') %></span>
      </article>
      <article class="platform-card platform-card--codeberg">
        <a class="platform-card__link" href="https://codeberg.org/">
          <span class="platform-logo" aria-hidden="true">
            <img class="platform-logo__image" src="<%= h app_path(platform_icon_path("codeberg")) %>" alt="" width="64" height="64">
          </span>
          <span class="platform-card__name">Codeberg</span>
        </a>
        <span class="platform-card__best-effort"><%= h t('about.platforms.best_effort') %></span>
      </article>
    </div>
  </div>
</section>
