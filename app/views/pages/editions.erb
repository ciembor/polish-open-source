<section class="hero">
  <div class="hero__inner">
    <div>
      <p class="eyebrow"><%= h t('editions.hero.eyebrow') %></p>
      <h1><%= h t('editions.title') %></h1>
      <p class="lede"><%= h t('editions.hero.lede') %></p>
      <% if @year %>
        <p class="period"><%= h t('editions.period_prefix') %> <%= h @year %></p>
      <% end %>
    </div>
  </div>
</section>

<%= erb :"shared/location_notice" %>

<% if @editions.empty? %>
  <section class="empty-state" aria-live="polite">
    <h2><%= h t('editions.empty.title') %></h2>
    <p><%= h t('editions.empty.body') %></p>
  </section>
<% else %>
  <section class="ranking-band" aria-labelledby="editions-heading">
    <div class="content">
      <div class="edition-header">
        <h2 id="editions-heading"><%= h @year %></h2>
        <nav class="edition-pagination" aria-label="<%= h t('editions.pagination_label') %>">
          <% if @newer_year %>
            <a class="ranking-action" href="<%= h app_path(editions_path(@newer_year)) %>"><%= h t('editions.newer_year') %></a>
          <% end %>
          <% if @older_year %>
            <a class="ranking-action" href="<%= h app_path(editions_path(@older_year)) %>"><%= h t('editions.older_year') %></a>
          <% end %>
        </nav>
      </div>

      <div class="edition-list">
        <% @editions.each do |edition| %>
          <% period_slug = Date.parse(edition.fetch(:period_start)).strftime('%Y-%m') %>
          <article class="edition-card">
            <header class="edition-card__header">
              <h3>
                <a class="primary-link" href="<%= h app_path(period_base_path(period_slug)) %>"><%= h period_label(edition.fetch(:period_start)) %></a>
              </h3>
            </header>

            <div class="edition-card__grid">
              <section>
                <h4><%= h t('editions.top_projects') %></h4>
                <ol class="edition-toplist">
                  <% edition.fetch(:repositories).each do |row| %>
                    <% source_url = safe_external_url(row[:html_url]) %>
                    <li>
                      <% if source_url %>
                        <a class="primary-link" href="<%= h source_url %>"><%= erb :"shared/platform_icon", locals: { platform: row.fetch(:platform, "github") } %><%= h row.fetch(:full_name) %></a>
                      <% else %>
                        <span class="primary-link"><%= erb :"shared/platform_icon", locals: { platform: row.fetch(:platform, "github") } %><%= h row.fetch(:full_name) %></span>
                      <% end %>
                      <span>⭐ <%= number(row.fetch(:stargazers_count)) %> <%= h t('editions.stars_suffix') %></span>
                    </li>
                  <% end %>
                </ol>
              </section>

              <section>
                <h4><%= h t('editions.top_users_stars') %></h4>
                <ol class="edition-toplist">
                  <% edition.fetch(:users_by_stars).each do |row| %>
                    <% source_url = safe_external_url(row[:html_url]) %>
                    <li>
                      <% if source_url %>
                        <a class="primary-link" href="<%= h source_url %>"><%= erb :"shared/platform_icon", locals: { platform: row.fetch(:platform, "github") } %><%= h row.fetch(:login) %></a>
                      <% else %>
                        <span class="primary-link"><%= erb :"shared/platform_icon", locals: { platform: row.fetch(:platform, "github") } %><%= h row.fetch(:login) %></span>
                      <% end %>
                      <span>⭐ <%= number(row.fetch(:total_stars)) %> <%= h t('editions.stars_suffix') %></span>
                    </li>
                  <% end %>
                </ol>
              </section>

              <section>
                <h4><%= h t('editions.top_users_merged_prs') %></h4>
                <ol class="edition-toplist">
                  <% edition.fetch(:users_by_merged_prs).each do |row| %>
                    <% source_url = safe_external_url(row[:html_url]) %>
                    <li>
                      <% if source_url %>
                        <a class="primary-link" href="<%= h source_url %>"><%= erb :"shared/platform_icon", locals: { platform: row.fetch(:platform, "github") } %><%= h row.fetch(:login) %></a>
                      <% else %>
                        <span class="primary-link"><%= erb :"shared/platform_icon", locals: { platform: row.fetch(:platform, "github") } %><%= h row.fetch(:login) %></span>
                      <% end %>
                      <span><%= number(row.fetch(:merged_pull_requests_count)) %> <%= h t('editions.merged_prs_suffix') %></span>
                    </li>
                  <% end %>
                </ol>
              </section>
            </div>
            <a class="edition-card__action" href="<%= h app_path(period_base_path(period_slug)) %>"><%= h t('editions.action.month_ranking') %></a>
          </article>
        <% end %>
      </div>
    </div>
  </section>
<% end %>
