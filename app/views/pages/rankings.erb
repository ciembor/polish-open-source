<section class="hero">
  <div class="hero__inner">
  <div>
    <p class="eyebrow"><%= h t('rankings.hero.eyebrow') %></p>
    <h1><%= h @ranking_section == 'organizations' ? t('rankings.hero.organizations_title', scope: scope_name(@scope)) : scope_name(@scope) %></h1>
    <p class="lede"><%= h t(@ranking_section == 'organizations' ? 'rankings.hero.organizations_lede' : 'rankings.hero.lede') %></p>
    <% if @period %>
      <p class="period"><%= h t('rankings.snapshot') %> <time datetime="<%= h @period %>"><%= h period_label(@period) %></time></p>
    <% end %>
  </div>

  <% if current_user %>
    <img class="hero__image" src="/images/polish_open_source_front.webp" alt="" aria-hidden="true">
  <% else %>
    <a class="hero__image-link" href="<%= h app_path('/auth/github') %>" aria-label="<%= h t('auth.login.github') %>">
      <img class="hero__image" src="/images/polish_open_source_front.webp" alt="" aria-hidden="true">
    </a>
  <% end %>

  </div>
</section>

<section class="location-nav-band">
  <div class="content">
    <%= erb :"shared/location_nav" %>
  </div>
</section>

<%= erb :"shared/location_notice" %>

<% unless @period %>
  <section class="empty-state" aria-live="polite">
    <h2><%= h t('rankings.empty.title') %></h2>
    <p><%= h t('rankings.empty.body') %></p>
  </section>
<% else %>
  <% if @ranking_section == 'people' %>
    <section class="ranking-band" aria-labelledby="users-heading">
      <div class="content">
        <h2 id="users-heading"><%= h t('rankings.users') %></h2>
        <div class="ranking-grid">
          <%= erb :"rankings/table", locals: { kind: "users", heading_id: 'ranking-users-top', title: t('rankings.top_10_stars'), rows: @user_rankings.fetch(:top).first(10), metric: :total_stars, metric_label: t('rankings.metric.stars'), top_path: ranking_path("users", "top") } %>
          <%= erb :"rankings/table", locals: { kind: "users", heading_id: 'ranking-users-trending', title: t('rankings.trending_10_month'), rows: @user_rankings.fetch(:trending).first(10), metric: :monthly_stars_delta, metric_label: t('rankings.metric.new_stars'), top_path: ranking_path("users", "trending") } %>
          <%= erb :"rankings/table", locals: { kind: "users", heading_id: 'ranking-users-active', title: t('rankings.users_merged_prs_month'), rows: @user_rankings.fetch(:active).first(10), metric: :merged_pull_requests_count, metric_label: t('rankings.metric.merged_pull_requests'), top_path: ranking_path("users", "active") } %>
        </div>
      </div>
    </section>

    <section class="ranking-band ranking-band--alt" aria-labelledby="repositories-heading">
      <div class="content">
        <h2 id="repositories-heading"><%= h t('rankings.repositories') %></h2>
        <div class="ranking-grid ranking-grid--two">
          <%= erb :"rankings/table", locals: { kind: "repositories", heading_id: 'ranking-repositories-top', title: t('rankings.top_10_stars'), rows: @repository_rankings.fetch(:top).first(10), metric: :stargazers_count, metric_label: t('rankings.metric.stars'), top_path: ranking_path("repositories", "top") } %>
          <%= erb :"rankings/table", locals: { kind: "repositories", heading_id: 'ranking-repositories-trending', title: t('rankings.trending_10_month'), rows: @repository_rankings.fetch(:trending).first(10), metric: :monthly_stars_delta, metric_label: t('rankings.metric.new_stars'), top_path: ranking_path("repositories", "trending") } %>
        </div>
      </div>
    </section>
  <% end %>

  <% if @ranking_section == 'organizations' %>
    <section class="ranking-band" aria-labelledby="organizations-heading">
      <div class="content">
        <h2 id="organizations-heading"><%= h t('rankings.organizations') %></h2>
        <div class="ranking-grid">
          <%= erb :"rankings/table", locals: { kind: "organizations", heading_id: 'ranking-organizations-top', title: t('rankings.top_10_stars'), rows: @organization_rankings.fetch(:top).first(10), metric: :total_stars, metric_label: t('rankings.metric.stars'), top_path: ranking_path("organizations", "top") } %>
          <%= erb :"rankings/table", locals: { kind: "organizations", heading_id: 'ranking-organizations-trending', title: t('rankings.trending_10_month'), rows: @organization_rankings.fetch(:trending).first(10), metric: :monthly_stars_delta, metric_label: t('rankings.metric.new_stars'), top_path: ranking_path("organizations", "trending") } %>
          <%= erb :"rankings/table", locals: { kind: "organizations", heading_id: 'ranking-organizations-members', title: t('rankings.members_10'), rows: @organization_rankings.fetch(:members).first(10), metric: :members_count, metric_label: t('rankings.metric.members'), top_path: ranking_path("organizations", "members") } %>
        </div>
      </div>
    </section>

    <section class="ranking-band ranking-band--alt" aria-labelledby="organization-repositories-heading">
      <div class="content">
        <h2 id="organization-repositories-heading"><%= h t('rankings.organization_repositories_month') %></h2>
        <div class="ranking-grid ranking-grid--two">
          <%= erb :"rankings/table", locals: { kind: "organization-repositories", heading_id: 'ranking-organization-repositories-top', title: t('rankings.top_10_stars'), rows: @organization_repository_rankings.fetch(:top).first(10), metric: :stargazers_count, metric_label: t('rankings.metric.stars'), top_path: ranking_path("organization-repositories", "top") } %>
          <%= erb :"rankings/table", locals: { kind: "organization-repositories", heading_id: 'ranking-organization-repositories-trending', title: t('rankings.trending_10_month'), rows: @organization_repository_rankings.fetch(:trending).first(10), metric: :monthly_stars_delta, metric_label: t('rankings.metric.new_stars'), top_path: ranking_path("organization-repositories", "trending") } %>
        </div>
      </div>
    </section>
  <% end %>
<% end %>
