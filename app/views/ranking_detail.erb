<section class="hero">
  <div class="hero__inner">
    <p class="eyebrow">Open-source ranking</p>
    <h1><%= h ranking_title(@kind, @metric) %></h1>
    <p class="lede"><%= h @scope.fetch(:name) %></p>
    <% if @period %>
      <p class="period">Snapshot: <time datetime="<%= h @period %>"><%= h @period %></time></p>
    <% end %>
  </div>
</section>

<section class="ranking-band">
  <div class="content">
    <p><a class="muted-link muted-link--standalone" href="<%= h app_path(scope_path(@scope)) %>">Wróć do rankingu</a></p>
    <% if @kind == "users" %>
      <%= erb :user_table, locals: { title: ranking_title(@kind, @metric), rows: @ranking, metric: ranking_metric_column(@kind, @metric), metric_label: ranking_metric_label(@kind, @metric) } %>
    <% else %>
      <%= erb :repository_table, locals: { title: ranking_title(@kind, @metric), rows: @ranking, metric: ranking_metric_column(@kind, @metric), metric_label: ranking_metric_label(@kind, @metric) } %>
    <% end %>
  </div>
</section>
