<section class="monitor-hero">
  <div class="content">
    <p class="eyebrow">Internal</p>
    <h1>Job monitor</h1>
    <% if @progress.fetch(:run) %>
      <% run = @progress.fetch(:run) %>
      <p class="lede">
        Monthly <%= h run.fetch(:period_start) %> to <%= h run.fetch(:period_end) %>,
        <strong><%= h run.fetch(:status) %></strong>,
        started <%= h format_monitor_time(run.fetch(:started_at)) %>.
        Last refresh <%= h format_monitor_time(@progress.fetch(:generated_at)) %>.
      </p>
    <% elsif @progress.fetch(:package_run) %>
      <% run = @progress.fetch(:package_run) %>
      <p class="lede">
        Packages <%= h run.fetch(:period_start) %>,
        <strong><%= h run.fetch(:status) %></strong>,
        started <%= h format_monitor_time(run.fetch(:started_at)) %>.
        Last refresh <%= h format_monitor_time(@progress.fetch(:generated_at)) %>.
      </p>
    <% else %>
      <p class="lede">No run has been recorded yet.</p>
    <% end %>
  </div>
</section>

<section class="monitor-section">
  <div class="content">
    <h2>Independent job stages</h2>
    <% sections = @progress.fetch(:sections) %>
    <% if sections.empty? %>
      <p class="monitor-empty">No stage progress has been recorded yet.</p>
    <% else %>
      <div class="monitor-table-wrap">
        <table class="monitor-table">
          <thead>
            <tr>
              <th>Stage</th>
              <th>Scope</th>
              <th>State</th>
              <th>Total</th>
              <th>Done</th>
              <th>Pending</th>
              <th>Failed</th>
              <th>Skipped</th>
              <th>Throughput/min</th>
              <th>Avg</th>
              <th>Median</th>
              <th>p95</th>
              <th>ETA avg</th>
              <th>ETA p95</th>
              <th>Status detail</th>
              <th>Last event</th>
            </tr>
          </thead>
          <tbody>
            <% sections.each do |section| %>
              <tr class="<%= section.fetch(:stale) ? 'is-stale' : '' %>">
                <th><%= h section.fetch(:label) %></th>
                <td>
                  <%= h [section[:platform], section[:ecosystem]].compact.join(' / ') %>
                </td>
                <td><%= h section.fetch(:state) %></td>
                <td><%= h section.fetch(:total) %></td>
                <td><%= h section.fetch(:done) %></td>
                <td><%= h section.fetch(:pending) %></td>
                <td><%= h section.fetch(:failed) %></td>
                <td><%= h section.fetch(:skipped) %></td>
                <td><%= h section.fetch(:throughput_per_minute) %></td>
                <td><%= h format_duration_ms(section.fetch(:average_ms)) %></td>
                <td><%= h format_duration_ms(section.fetch(:median_ms)) %></td>
                <td><%= h format_duration_ms(section.fetch(:p95_ms)) %></td>
                <td><%= h format_duration_seconds(section.fetch(:eta_average_seconds)) %></td>
                <td><%= h format_duration_seconds(section.fetch(:eta_p95_seconds)) %></td>
                <td><%= h(section.fetch(:status_detail) || 'n/a') %></td>
                <td>
                  <%= h format_monitor_time(section.fetch(:last_finished_at)) %>
                  <% if section.fetch(:stale) %><span class="monitor-warning">stale</span><% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</section>

<section class="monitor-section monitor-section--alt">
  <div class="content">
    <h2>Recent logs</h2>
    <div class="monitor-log-grid">
      <article class="monitor-log-panel">
        <h3>Last monitor events</h3>
        <% events = @progress.fetch(:recent_events) %>
        <% if events.empty? %>
          <p class="monitor-empty">No events recorded for this run yet.</p>
        <% else %>
          <ol class="monitor-log-list">
            <% events.each do |event| %>
              <li>
                <time><%= h format_monitor_time(event.fetch(:recorded_at)) %></time>
                <strong><%= h event.fetch(:platform) %> / <%= h event.fetch(:source) %></strong>
                <span><%= h event.fetch(:subject) %></span>
                <small><%= h event.fetch(:detail) %></small>
              </li>
            <% end %>
          </ol>
        <% end %>
      </article>

      <article class="monitor-log-panel">
        <h3>Last error logs</h3>
        <% errors = @progress.fetch(:recent_errors) %>
        <% if errors.empty? %>
          <p class="monitor-empty">No job work errors recorded.</p>
        <% else %>
          <ol class="monitor-log-list monitor-log-list--errors">
            <% errors.each do |event| %>
              <li>
                <time><%= h format_monitor_time(event.fetch(:finished_at)) %></time>
                <strong><%= h event.fetch(:job_kind) %> / <%= h event.fetch(:stage) %></strong>
                <span><%= h event.fetch(:subject_label) %></span>
                <small><%= h event.fetch(:error) %></small>
              </li>
            <% end %>
          </ol>
        <% end %>
      </article>
    </div>
  </div>
</section>
