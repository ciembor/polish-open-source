<article class="ranking-table" aria-labelledby="<%= h heading_id %>">
  <h3 id="<%= h heading_id %>"><%= h title %></h3>
  <% if rows.any? %>
    <ol class="ranking-list" aria-labelledby="<%= h heading_id %>">
      <% rows.each_with_index do |row, index| %>
        <% registry_url = safe_external_url(row[:registry_url]) %>
        <% repository_profile_url = package_repository_profile_link(row) %>
        <% repository_source_url = package_repository_link(row) %>
        <% owner_display_name = package_owner_display_name(row) %>
        <li class="ranking-list__item">
          <span class="rank-cell rank-mark"><%= index + 1 %></span>
          <div class="ranking-list__body">
            <div class="ranking-list__title">
              <% if repository_profile_url %>
                <a class="primary-link" href="<%= h repository_profile_url %>"><%= h row.fetch(:package_name) %></a>
              <% else %>
                <span><%= h row.fetch(:package_name) %></span>
              <% end %>
              <% if owner_display_name %>
                <span class="ranking-list__title-meta"> - <%= h owner_display_name %></span>
              <% end %>
            </div>
            <% if row[:repository_description] && !row[:repository_description].empty? %>
              <span class="ranking-list__description"><%= h row[:repository_description] %></span>
            <% end %>
          </div>
          <div class="ranking-list__metrics">
            <span class="metric" title="<%= h metric_label %>" aria-label="<%= h metric_label %>: <%= h number(row.fetch(metric)) %>">
              <%= h metric_value(metric, row.fetch(metric)) %>
            </span>
          </div>
          <span class="ranking-list__links ranking-list__links--edge">
            <% if repository_source_url %>
              <a class="muted-link" href="<%= h repository_source_url %>"><%= h platform_name(row.fetch(:repository_platform)) %></a>
            <% end %>
            <% if registry_url %>
              <a class="muted-link" href="<%= h registry_url %>"><%= h t('packages.links.package') %></a>
            <% end %>
          </span>
        </li>
      <% end %>
    </ol>
  <% else %>
    <p class="ranking-list__empty"><%= h t('rankings.empty.records') %></p>
  <% end %>
  <% if defined?(top_path) && top_path %>
    <a class="ranking-action" href="<%= h app_path(top_path) %>"><%= h t('rankings.see_top_100') %></a>
  <% end %>
</article>
