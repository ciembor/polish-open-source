<section class="hero">
  <div class="hero__inner">
    <div>
      <p class="eyebrow"><%= h t('packages.hero.eyebrow') %></p>
      <h1><%= h t('packages.ecosystem.title', ecosystem: @package_ecosystem) %></h1>
      <p class="lede"><%= h t('packages.ecosystem.lede') %></p>
      <% if @period %>
        <p class="period"><%= h t('rankings.snapshot') %> <time datetime="<%= h @period %>"><%= h period_label(@period) %></time></p>
      <% end %>
    </div>
    <img class="hero__image" src="/images/polish_open_source_front.webp" alt="" aria-hidden="true">
  </div>
</section>

<%= erb :"shared/location_notice" %>

<section class="ranking-band" aria-labelledby="package-ranking-all-heading">
  <div class="content">
    <p><a class="muted-link muted-link--standalone" href="<%= h app_path(package_index_path) %>"><%= h t('packages.back') %></a></p>
    <h2 id="package-ranking-all-heading"><%= h t('packages.repository_kind.all') %></h2>
    <div class="ranking-grid ranking-grid--package-metrics">
      <% PolishOpenSourceRank::Contexts::Packages::Domain::PackageRankingMetric.all(ecosystem: @package_ecosystem).each do |package_metric| %>
        <% slug = package_metric.slug %>
        <% metric = package_metric.key.to_sym %>
        <%= erb :"packages/ranking_table", locals: { heading_id: "package-ranking-all-#{slug}", title: package_ranking_preview_title(slug, ecosystem: @package_ecosystem), rows: @package_rankings.fetch(metric, []), metric: metric, metric_label: package_metric_label(metric, ecosystem: @package_ecosystem), top_path: package_ranking_path(@package_ecosystem, slug) } %>
      <% end %>
    </div>
  </div>
</section>

<% @package_ranking_groups.each_with_index do |(repository_kind, rankings), index| %>
  <section class="ranking-band<%= index.even? ? ' ranking-band--alt' : '' %>" aria-labelledby="package-ranking-<%= h repository_kind %>-heading">
    <div class="content">
      <h2 id="package-ranking-<%= h repository_kind %>-heading"><%= h package_repository_kind_label(repository_kind) %></h2>
      <div class="ranking-grid ranking-grid--package-metrics">
        <% PolishOpenSourceRank::Contexts::Packages::Domain::PackageRankingMetric.all(ecosystem: @package_ecosystem).each do |package_metric| %>
          <% slug = package_metric.slug %>
          <% metric = package_metric.key.to_sym %>
          <%= erb :"packages/ranking_table", locals: { heading_id: "package-ranking-#{repository_kind}-#{slug}", title: package_repository_ranking_preview_title(slug, ecosystem: @package_ecosystem), rows: rankings.fetch(metric, []), metric: metric, metric_label: package_metric_label(metric, ecosystem: @package_ecosystem), top_path: package_repository_ranking_path(@package_ecosystem, repository_kind, slug) } %>
        <% end %>
      </div>
    </div>
  </section>
<% end %>
