<section class="hero">
  <div class="hero__inner">
    <div>
      <p class="eyebrow"><%= h t('packages.hero.eyebrow') %></p>
      <% title = @package_repository_kind ? package_repository_ranking_title(@package_metric_slug, ecosystem: @package_ecosystem, repository_kind: @package_repository_kind) : package_ranking_title(@package_metric_slug, ecosystem: @package_ecosystem) %>
      <h1><%= h title %></h1>
      <p class="lede"><%= h @package_ecosystem %></p>
      <% if @period %>
        <p class="period"><%= h t('rankings.snapshot') %> <time datetime="<%= h @period %>"><%= h period_label(@period) %></time></p>
      <% end %>
    </div>

    <% if current_user %>
      <img class="hero__image" src="/images/polish_open_source_front.webp" alt="" aria-hidden="true">
    <% else %>
      <a class="hero__image-link" href="<%= h app_path('/auth/github') %>" aria-label="<%= h t('auth.login.github') %>">
        <img class="hero__image" src="/images/polish_open_source_front.webp" alt="" aria-hidden="true">
      </a>
    <% end %>
  </div>
</section>

<%= erb :"shared/location_notice" %>

<section class="ranking-band">
  <div class="content">
    <p><a class="muted-link muted-link--standalone" href="<%= h app_path(package_ecosystem_path(@package_ecosystem)) %>"><%= h t('rankings.back') %></a></p>
    <%= erb :"packages/ranking_table", locals: { heading_id: "package-ranking-detail-#{@package_metric_slug}", title: title, rows: @package_ranking, metric: @package_metric.to_sym, metric_label: package_metric_label(@package_metric, ecosystem: @package_ecosystem) } %>
  </div>
</section>
