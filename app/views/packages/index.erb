<section class="hero">
  <div class="hero__inner">
    <div>
      <p class="eyebrow"><%= h t('packages.hero.eyebrow') %></p>
      <h1><%= h t('packages.title') %></h1>
      <p class="lede"><%= h t('packages.hero.lede') %></p>
      <% if @period %>
        <p class="period"><%= h t('rankings.snapshot') %> <time datetime="<%= h @period %>"><%= h period_label(@period) %></time></p>
      <% end %>
    </div>
    <img class="hero__image" src="/images/polish_open_source_front.webp" alt="" aria-hidden="true">
  </div>
</section>

<%= erb :"shared/location_notice" %>

<section class="ranking-band" aria-labelledby="package-ecosystems-heading">
  <div class="content">
    <h2 id="package-ecosystems-heading"><%= h t('packages.title') %></h2>
    <% if @package_cards.any? %>
      <div class="index-card-grid">
        <% @package_cards.each do |card| %>
          <% ecosystem = card.fetch(:ecosystem) %>
          <article class="index-card">
            <div class="index-card__header">
              <img class="index-card__icon" src="<%= h package_ecosystem_icon_path(ecosystem) %>" alt="" aria-hidden="true">
              <h3><a class="primary-link" href="<%= h app_path(package_ecosystem_path(ecosystem)) %>"><%= h package_ecosystem_name(ecosystem) %></a></h3>
            </div>
            <dl class="index-card__metrics">
              <div>
                <dt><%= h t('languages.metric.repository.count') %></dt>
                <dd>🗂️ <%= h number(card.fetch(:repository_count)) %></dd>
              </div>
              <div>
                <dt><%= h t('rankings.metric.stars') %></dt>
                <dd>⭐ <%= h number(card.fetch(:repository_stars_count)) %></dd>
              </div>
            </dl>
            <a class="ranking-action" href="<%= h app_path(package_ecosystem_path(ecosystem)) %>"><%= h t('packages.ecosystem.action') %></a>
          </article>
        <% end %>
      </div>
    <% else %>
      <p class="ranking-list__empty"><%= h t('packages.empty') %></p>
    <% end %>
  </div>
</section>
