<%= erb :profile_project_hero, locals: { record: @repository } %>

<section class="profile-section" aria-labelledby="repository-summary-heading">
  <div class="content profile-grid">
    <article class="profile-summary">
      <h2 id="repository-summary-heading"><%= h t('repositories.summary.title') %></h2>
      <dl class="profile-facts">
        <div>
          <dt><%= h t('repositories.summary.owner') %></dt>
          <dd><a class="primary-link" href="<%= h app_path(user_profile_path(platform: @repository.fetch(:platform), login: @repository.fetch(:owner_login))) %>"><%= h @repository.fetch(:owner_login) %></a></dd>
        </div>
        <div>
          <dt><%= h t('users.summary.city') %></dt>
          <dd><%= h(@repository[:owner_city] || t('users.summary.unknown')) %></dd>
        </div>
        <% if @repository[:language] && !@repository[:language].empty? %>
          <div>
            <dt><%= h t('users.repositories.language') %></dt>
            <dd><%= h @repository[:language] %></dd>
          </div>
        <% end %>
      </dl>
    </article>

    <% metric_items = [
      { label: t('rankings.metric.stars'), value: "⭐ #{number(@repository[:stargazers_count])}" },
      { label: t('rankings.metric.new_stars'), value: "⭐ #{number(@repository[:monthly_stars_delta])}" }
    ] %>
    <% if @show_repository_badge && @repository[:polish_repo_badge] && @repository[:polish_repo_badge][:value] %>
      <% metric_items << { label: @repository[:polish_repo_badge].fetch(:label), value: @repository[:polish_repo_badge].fetch(:value) } %>
    <% end %>
    <%= erb :profile_metric_card, locals: {
      title: t('users.metrics.title'),
      period_start: @repository[:period_start],
      empty_message: nil,
      items: metric_items
    } %>
  </div>
</section>

<% if @show_repository_badge && @repository[:polish_repo_badge] && @repository[:polish_repo_badge][:value] %>
  <section class="profile-section profile-section--alt" aria-labelledby="repository-badge-heading">
    <div class="content">
      <h2 id="repository-badge-heading"><%= h t('repositories.badge.title') %></h2>
      <%= erb :badge_preview, locals: { label: @repository.fetch(:full_name), badge_path: repository_badge_path(@repository), alt_text: t('repositories.badge.alt') } %>
    </div>
  </section>
<% end %>
