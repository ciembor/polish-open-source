<section class="hero">
  <div class="hero__inner">
    <div>
      <p class="eyebrow"><%= h t('languages.hero.eyebrow') %></p>
      <h1><%= h language_repository_ranking_title(@language, @language_repository_kind, @language_repository_metric_slug) %></h1>
      <p class="lede"><%= h t('languages.language_lede', language: @language) %></p>
      <% if @period %>
        <p class="period"><%= h t('rankings.snapshot') %> <time datetime="<%= h @period %>"><%= h period_label(@period) %></time></p>
      <% end %>
    </div>
    <img class="hero__image" src="/images/polish_open_source_front.webp" alt="" aria-hidden="true">
  </div>
</section>

<%= erb :"shared/location_notice" %>

<section class="ranking-band">
  <div class="content">
    <p><a class="muted-link muted-link--standalone" href="<%= h app_path(language_path(@language)) %>"><%= h t('languages.back_to_language', language: @language) %></a></p>
    <%= erb :"languages/repository_ranking_table", locals: { heading_id: "language-repository-ranking-detail-#{@language_repository_kind}-#{@language_repository_metric_slug}", title: language_repository_ranking_title(@language, @language_repository_kind, @language_repository_metric_slug), rows: @language_repository_ranking, metric: @language_repository_metric.to_sym, metric_label: language_metric_label(@language_repository_metric) } %>
  </div>
</section>
