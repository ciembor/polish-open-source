<section class="hero">
  <div class="hero__inner">
    <div>
      <p class="eyebrow"><%= h t('languages.hero.eyebrow') %></p>
      <h1><%= h t('languages.title') %></h1>
      <p class="lede"><%= h t('languages.hero.lede') %></p>
      <% if @period %>
        <p class="period"><%= h t('rankings.snapshot') %> <time datetime="<%= h @period %>"><%= h period_label(@period) %></time></p>
      <% end %>
    </div>
    <img class="hero__image" src="/images/polish_open_source_front.webp" alt="" aria-hidden="true">
  </div>
</section>

<%= erb :"shared/location_notice" %>

<section class="ranking-band" aria-labelledby="language-rankings-heading">
  <div class="content">
    <h2 id="language-rankings-heading"><%= h t('languages.title') %></h2>
    <% if @language_cards.any? %>
      <div class="index-card-grid">
        <% @language_cards.each do |card| %>
          <% language = card.fetch(:language) %>
          <article class="index-card">
            <div class="index-card__header">
              <img class="index-card__icon" src="<%= h language_icon_path(language) %>" alt="" aria-hidden="true">
              <h3><a class="primary-link" href="<%= h app_path(language_path(language)) %>"><%= h language %></a></h3>
            </div>
            <p class="index-card__description"><%= h language_description(language) %></p>
            <dl class="index-card__metrics">
              <div>
                <dt><%= h t('languages.metric.repository.count') %></dt>
                <dd><%= h number(card.fetch(:repository_count)) %></dd>
              </div>
              <div>
                <dt><%= h t('rankings.metric.stars') %></dt>
                <dd><%= h number(card.fetch(:repository_stars_count)) %></dd>
              </div>
            </dl>
            <a class="ranking-action" href="<%= h app_path(language_path(language)) %>"><%= h t('languages.action') %></a>
          </article>
        <% end %>
      </div>
    <% else %>
      <p class="ranking-list__empty"><%= h t('rankings.empty.records') %></p>
    <% end %>
  </div>
</section>
