<section class="hero">
  <div class="hero__inner">
    <div>
      <p class="eyebrow"><%= h t('languages.hero.eyebrow') %></p>
      <h1><%= h t('languages.title') %></h1>
      <p class="lede"><%= h t('languages.hero.lede') %></p>
      <% if @period %>
        <p class="period"><%= h t('rankings.snapshot') %> <time datetime="<%= h @period %>"><%= h period_label(@period) %></time></p>
      <% end %>
    </div>
    <img class="hero__image" src="/images/polish_open_source_front.webp" alt="" aria-hidden="true">
  </div>
</section>

<%= erb :"shared/location_notice" %>

<section class="ranking-band" aria-labelledby="language-rankings-heading">
  <div class="content">
    <h2 id="language-rankings-heading"><%= h t('languages.title') %></h2>
    <div class="ranking-grid ranking-grid--compact">
      <% PolishOpenSourceRank::Contexts::Languages::Domain::LanguageRankingMetric.all.each do |language_metric| %>
        <% slug = language_metric.slug %>
        <% metric = language_metric.key.to_sym %>
        <%= erb :"languages/ranking_table", locals: { heading_id: "language-ranking-#{slug}", title: language_ranking_preview_title(slug), rows: @language_rankings.fetch(metric, []), metric: metric, metric_label: language_metric_label(metric), top_path: language_ranking_path(slug) } %>
      <% end %>
    </div>
  </div>
</section>
