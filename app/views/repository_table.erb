<article class="ranking-table">
  <h3><%= h title %></h3>
  <table>
    <thead>
      <tr>
        <th scope="col">#</th>
        <th scope="col"><%= h t('rankings.repository') %></th>
        <th scope="col">Owner</th>
        <th scope="col"><%= h metric_label %></th>
      </tr>
    </thead>
    <tbody>
      <% rows.each_with_index do |row, index| %>
        <tr>
          <td class="rank-cell">
            <span class="rank-mark">
              <%= erb :elite_medal, locals: { rank: index + 1 } %>
              <%= index + 1 %>
            </span>
          </td>
          <td>
            <%= erb :platform_icon, locals: { platform: row.fetch(:platform, "github") } %>
            <a class="primary-link" href="<%= h app_path(repository_profile_path(row)) %>"><%= h row.fetch(:full_name) %></a>
            <% if row[:description] && !row[:description].empty? %>
              <span><%= h row[:description] %></span>
            <% end %>
          </td>
          <td><a class="muted-link muted-link--standalone" href="<%= h app_path(user_profile_path(row.merge(login: row.fetch(:owner_login)))) %>"><%= h row.fetch(:owner_login) %></a></td>
          <td class="metric"><%= number(row.fetch(metric)) %></td>
        </tr>
      <% end %>
      <% if rows.empty? %>
        <tr>
          <td colspan="4"><%= h t('rankings.empty.records') %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if defined?(top_path) && top_path %>
    <a class="ranking-action" href="<%= h app_path(top_path) %>"><%= h t('rankings.see_top_100') %></a>
  <% end %>
</article>
