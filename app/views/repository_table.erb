<article class="ranking-table">
  <h3><%= h title %></h3>
  <table>
    <thead>
      <tr>
        <th scope="col">#</th>
        <th scope="col">Repozytorium</th>
        <th scope="col">Owner</th>
        <th scope="col"><%= h metric_label %></th>
      </tr>
    </thead>
    <tbody>
      <% rows.each_with_index do |row, index| %>
        <tr>
          <td><%= index + 1 %></td>
          <td>
            <a class="primary-link" href="<%= h row.fetch(:html_url) %>"><%= h row.fetch(:full_name) %></a>
            <% if row[:description] && !row[:description].empty? %>
              <span><%= h row[:description] %></span>
            <% end %>
          </td>
          <td><%= h row.fetch(:owner_login) %></td>
          <td class="metric"><%= number(row.fetch(metric)) %></td>
        </tr>
      <% end %>
      <% if rows.empty? %>
        <tr>
          <td colspan="4">Brak rekordów.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</article>

