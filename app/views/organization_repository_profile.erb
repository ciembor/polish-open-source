<%= erb :profile_project_hero, locals: { record: @organization_repository } %>

<section class="profile-section" aria-labelledby="organization-repository-summary-heading">
  <div class="content profile-grid">
    <article class="profile-summary">
      <h2 id="organization-repository-summary-heading"><%= h t('repositories.summary.title') %></h2>
      <dl class="profile-facts">
        <div>
          <dt><%= h t('repositories.summary.owner') %></dt>
          <dd><a class="primary-link" href="<%= h app_path(organization_profile_path(platform: @organization_repository.fetch(:platform), login: @organization_repository.fetch(:organization_login))) %>"><%= h @organization_repository.fetch(:organization_login) %></a></dd>
        </div>
        <div>
          <dt><%= h t('users.summary.city') %></dt>
          <dd><%= h(@organization_repository[:organization_city] || t('users.summary.unknown')) %></dd>
        </div>
        <% if @organization_repository[:language] && !@organization_repository[:language].empty? %>
          <div>
            <dt><%= h t('users.repositories.language') %></dt>
            <dd><%= h @organization_repository[:language] %></dd>
          </div>
        <% end %>
      </dl>
    </article>

    <% metric_items = [
      { label: t('rankings.metric.stars'), value: "⭐ #{number(@organization_repository[:stargazers_count])}" },
      { label: t('rankings.metric.new_stars'), value: "⭐ #{number(@organization_repository[:monthly_stars_delta])}" }
    ] %>
    <% if @organization_repository[:polish_repo_badge] && @organization_repository[:polish_repo_badge][:value] %>
      <% metric_items << { label: @organization_repository[:polish_repo_badge].fetch(:label), value: @organization_repository[:polish_repo_badge].fetch(:value) } %>
    <% end %>
    <%= erb :profile_metric_card, locals: {
      title: t('users.metrics.title'),
      period_start: @organization_repository[:period_start],
      empty_message: nil,
      items: metric_items
    } %>
  </div>
</section>
