<%= erb :profile_subject_hero, locals: { record: @organization, translation_scope: 'organizations', translation_value_key: :organization } %>

<% top_repository = @repositories.first %>
<section class="profile-section profile-section--compact" aria-labelledby="organization-spotlight-heading">
  <div class="content">
    <article class="profile-spotlight">
      <div class="profile-spotlight__header">
        <h2 id="organization-spotlight-heading"><%= h t('organizations.spotlight.title') %></h2>
        <% if @organization[:period_start] %>
          <p class="period"><%= h t('rankings.snapshot') %> <time datetime="<%= h @organization[:period_start] %>"><%= h period_label(@organization[:period_start]) %></time></p>
        <% end %>
      </div>

      <dl class="profile-spotlight__grid">
        <div class="profile-spotlight__item">
          <dt><%= h t('organizations.spotlight.country_rank') %></dt>
          <dd><%= h(@organization[:elite_rank] ? "##{@organization[:elite_rank]}" : '-') %></dd>
        </div>

        <% if @organization[:city] %>
          <div class="profile-spotlight__item">
            <dt><%= h t('organizations.spotlight.city') %></dt>
            <dd><%= h @organization.fetch(:city) %></dd>
          </div>
        <% end %>

        <% if top_repository %>
          <div class="profile-spotlight__item profile-spotlight__item--repository">
            <dt><%= h t('organizations.spotlight.top_repository') %></dt>
            <dd>
              <a class="primary-link" href="<%= h app_path(organization_repository_profile_path(top_repository)) %>"><%= h top_repository.fetch(:full_name) %></a>
              <span class="profile-spotlight__meta">⭐ <%= number(top_repository.fetch(:stargazers_count)) %></span>
            </dd>
          </div>
        <% end %>
      </dl>
    </article>
  </div>
</section>

<section class="profile-section profile-section--alt" aria-labelledby="organization-badge-heading">
  <div class="content">
    <h2 id="organization-badge-heading"><%= h t('organizations.badge.title') %></h2>
    <%= erb :badge_preview, locals: { label: @organization.fetch(:login), badge_path: organization_badge_path(@organization), alt_text: t('organizations.badge.alt') } %>
  </div>
</section>

<section class="profile-section" aria-labelledby="organization-summary-heading">
  <div class="content profile-grid">
    <article class="profile-summary">
      <h2 id="organization-summary-heading"><%= h t('organizations.summary.title') %></h2>
      <dl class="profile-facts">
        <div>
          <dt><%= h t('organizations.summary.location') %></dt>
          <dd><%= h(@organization[:location_raw] || @organization[:city] || @organization[:country] || t('users.summary.unknown')) %></dd>
        </div>
        <div>
          <dt><%= h t('users.summary.city') %></dt>
          <dd><%= h(@organization[:city] || t('users.summary.unknown')) %></dd>
        </div>
        <div>
          <dt><%= h t('organizations.summary.public_repositories') %></dt>
          <dd><%= number(@organization[:public_repo_count]) %></dd>
        </div>
      </dl>
    </article>

    <article class="profile-summary">
      <h2><%= h t('users.metrics.title') %></h2>
      <% if @organization[:period_start] %>
        <p class="period"><%= h t('rankings.snapshot') %> <time datetime="<%= h @organization[:period_start] %>"><%= h period_label(@organization[:period_start]) %></time></p>
      <% else %>
        <p class="profile-empty"><%= h t('users.metrics.outside_ranking') %></p>
      <% end %>
      <dl class="profile-metrics">
        <% if !@organization[:total_stars].nil? %>
          <div>
            <dt><%= h t('rankings.metric.stars') %></dt>
            <dd>⭐ <%= number(@organization[:total_stars]) %></dd>
          </div>
        <% end %>
        <% if !@organization[:monthly_stars_delta].nil? %>
          <div>
            <dt><%= h t('rankings.metric.new_stars') %></dt>
            <dd>⭐ <%= number(@organization[:monthly_stars_delta]) %></dd>
          </div>
        <% end %>
        <div>
          <dt><%= h @organization.fetch(:profile_badge).fetch(:label) %></dt>
          <dd><%= h(@organization.fetch(:profile_badge)[:value] || t('users.metrics.outside_ranking')) %></dd>
        </div>
      </dl>
    </article>
  </div>
</section>

<section class="profile-section profile-section--alt" aria-labelledby="organization-repositories-heading">
  <div class="content">
    <h2 id="organization-repositories-heading"><%= h t('organizations.repositories.title') %></h2>
    <%= erb :profile_repository_grid, locals: {
      repositories: @repositories,
      empty_translation_key: 'organizations.repositories.empty',
      path_builder: method(:organization_repository_profile_path),
      show_homepage: false
    } %>
  </div>
</section>
