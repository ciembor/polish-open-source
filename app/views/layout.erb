<!doctype html>
<html lang="<%= h current_locale %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="<%= h(@robots || 'index,follow') %>">
    <meta name="description" content="<%= h @description %>">
    <meta property="og:title" content="<%= h @title %>">
    <meta property="og:description" content="<%= h @description %>">
    <meta property="og:url" content="<%= h canonical_url %>">
    <meta property="og:type" content="<%= h open_graph_type %>">
    <meta property="og:image" content="<%= h social_image_url %>">
    <meta property="og:site_name" content="Polish Open Source">
    <meta property="og:locale" content="<%= h og_locale %>">
    <% if localized_page? %>
      <% og_alternate_locales.each do |locale| %>
        <meta property="og:locale:alternate" content="<%= h locale %>">
      <% end %>
    <% end %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= h @title %>">
    <meta name="twitter:description" content="<%= h @description %>">
    <meta name="twitter:image" content="<%= h social_image_url %>">
    <link rel="icon" href="<%= h asset_path('/icons/favicon.ico') %>" sizes="any">
    <link rel="icon" type="image/png" sizes="32x32" href="<%= h asset_path('/icons/favicon-32x32.png') %>">
    <link rel="icon" type="image/png" sizes="16x16" href="<%= h asset_path('/icons/favicon-16x16.png') %>">
    <link rel="apple-touch-icon" sizes="180x180" href="<%= h asset_path('/icons/apple-touch-icon.png') %>">
    <link rel="canonical" href="<%= h canonical_url %>">
    <% if localized_page? %>
      <% alternate_locale_urls.each do |locale, url| %>
        <link rel="alternate" hreflang="<%= h locale %>" href="<%= h url %>">
      <% end %>
      <link rel="alternate" hreflang="x-default" href="<%= h alternate_locale_urls.fetch('pl') %>">
    <% end %>
    <% settings.css_asset_files.each do |css_path| %>
      <link rel="stylesheet" href="<%= h asset_path(css_path) %>">
    <% end %>
    <% if @refresh_seconds %>
      <meta http-equiv="refresh" content="<%= h @refresh_seconds %>">
    <% end %>
    <title><%= h @title %></title>
    <script type="application/ld+json">
      <%= structured_data %>
    </script>
    <script defer src="<%= h asset_path('/js/navigation.js') %>"></script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href="<%= h period_base_path('latest') %>"><img src="/icons/polish-open-source.png" alt="" aria-hidden="true">Polish Open Source</a>
        <nav class="nav js-nav" aria-label="<%= h t('nav.menu') %>">
          <a class="nav__link js-secondary-control js-collapsible-control <%= active_nav_link_class(:people) %>" href="<%= h app_path(people_rankings_path(period_slug: 'latest')) %>"><%= h t('nav.people') %></a>
          <a class="nav__link js-secondary-control js-collapsible-control <%= active_nav_link_class(:organizations) %>" href="<%= h app_path(organization_rankings_path(period_slug: 'latest')) %>"><%= h t('nav.organizations') %></a>
          <div class="nav-slot js-secondary-controls-slot">
            <a class="nav__link js-secondary-control js-collapsible-control <%= active_nav_link_class(:languages) %>" href="<%= h app_path(language_index_path(period_slug: 'latest')) %>"><%= h t('nav.languages') %></a>
            <a class="nav__link js-secondary-control js-collapsible-control <%= active_nav_link_class(:packages) %>" href="<%= h app_path(package_index_path(period_slug: 'latest')) %>"><%= h t('nav.packages') %></a>
            <a class="nav__link js-secondary-control js-collapsible-control <%= active_nav_link_class(:editions) %>" href="<%= h app_path(editions_path) %>"><%= h t('nav.editions') %></a>
            <a class="nav__link js-secondary-control js-collapsible-control <%= active_nav_link_class(:about) %>" href="<%= h app_path('/about') %>"><%= h t('nav.about') %></a>
            <% if current_user %>
              <a class="nav__link js-secondary-control js-collapsible-control <%= active_nav_link_class(:profile) %>" href="<%= h app_path(user_profile_path(current_user)) %>"><%= h t('nav.profile') %></a>
            <% end %>
          </div>
          <details class="nav-menu nav-menu--hamburger js-hamburger" hidden>
            <summary class="nav-hamburger" aria-label="<%= h t('nav.menu') %>"></summary>
            <div class="nav-menu__panel js-hamburger-panel"></div>
          </details>
          <% if current_user %>
            <form class="nav-form js-fixed-control" method="post" action="<%= h app_path('/logout') %>">
              <input type="hidden" name="csrf_token" value="<%= h csrf_token %>">
              <button class="nav-pill" type="submit"><%= h t('auth.logout') %></button>
            </form>
          <% else %>
            <a class="nav-pill nav-pill--github js-fixed-control" href="<%= h app_path('/auth/github') %>" aria-label="<%= h t('auth.login.github') %>">
              <img class="nav-pill__icon" src="<%= h app_path('/icons/github.svg') %>" alt="" aria-hidden="true" />
              <span><%= h t('auth.login.github') %></span>
            </a>
          <% end %>
          <div class="language-switch js-fixed-control" role="navigation" aria-label="<%= h t('nav.language') %>">
            <% SUPPORTED_LOCALES.each do |locale| %>
              <a class="language-switch__link <%= 'is-active' if current_locale?(locale) %>" href="<%= h locale_path(locale) %>" hreflang="<%= h locale %>" lang="<%= h locale %>"><%= h locale.upcase %></a>
            <% end %>
          </div>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <% if auth_notice %>
        <section class="site-notice" aria-live="polite">
          <div class="content">
            <p><%= h t("auth.notice.#{auth_notice}") %></p>
          </div>
        </section>
      <% end %>
      <%= yield %>
    </main>

    <section class="site-author" aria-label="<%= h t('site_author.label') %>">
      <div class="content site-author__inner">
        <img class="site-author__avatar" src="/images/maciej-ciemborowicz.jpg" alt="" aria-hidden="true" width="56" height="56">
        <div class="site-author__identity">
          <span class="site-author__name">Maciej Ciemborowicz</span>
          <span class="site-author__links">
            <a class="site-author__link" href="https://maciej-ciemborowicz.eu/" target="_blank" rel="noopener noreferrer" aria-label="<%= h t('site_author.links.homepage') %>">
              <img src="<%= h app_path('/icons/home.svg') %>" alt="" aria-hidden="true">
              <span><%= h t('site_author.link_text.homepage') %></span>
            </a>
            <a class="site-author__link" href="https://github.com/ciembor" target="_blank" rel="noopener noreferrer" aria-label="<%= h t('site_author.links.github') %>">
              <img src="<%= h app_path('/icons/github.svg') %>" alt="" aria-hidden="true">
              <span><%= h t('site_author.link_text.github') %></span>
            </a>
            <a class="site-author__link" href="https://www.linkedin.com/in/maciej-ciemborowicz/" target="_blank" rel="noopener noreferrer" aria-label="<%= h t('site_author.links.linkedin') %>">
              <img src="<%= h app_path('/icons/linkedin.svg') %>" alt="" aria-hidden="true">
              <span><%= h t('site_author.link_text.linkedin') %></span>
            </a>
            <a class="site-author__link" href="https://x.com/ciembor" target="_blank" rel="noopener noreferrer" aria-label="<%= h t('site_author.links.x') %>">
              <img src="<%= h app_path('/icons/x.svg') %>" alt="" aria-hidden="true">
              <span><%= h t('site_author.link_text.x') %></span>
            </a>
          </span>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <p><a href="https://www.youtube.com/watch?v=6c-RbGZBnBI" target="_blank" rel="noopener noreferrer">So that when the moment comes, I can say I did it all with love.</a></p>
    </footer>
    <a
      class="github-ribbon"
      href="https://github.com/ciembor/polish-open-source"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="<%= h t('github_ribbon.label') %>"
    >
      <img class="github-ribbon__icon" src="<%= h app_path('/icons/github.svg') %>" alt="" aria-hidden="true">
      <span><%= h t('github_ribbon.text') %></span>
    </a>
  </body>
</html>
