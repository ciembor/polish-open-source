<!doctype html>
<html lang="<%= h current_locale %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="<%= h(@robots || 'index,follow') %>">
    <meta name="description" content="<%= h @description %>">
    <link rel="icon" href="<%= h asset_path('/icons/favicon.ico') %>" sizes="any">
    <link rel="icon" type="image/png" sizes="32x32" href="<%= h asset_path('/icons/favicon-32x32.png') %>">
    <link rel="icon" type="image/png" sizes="16x16" href="<%= h asset_path('/icons/favicon-16x16.png') %>">
    <link rel="apple-touch-icon" sizes="180x180" href="<%= h asset_path('/icons/apple-touch-icon.png') %>">
    <link rel="canonical" href="<%= h canonical_url %>">
    <link rel="stylesheet" href="<%= h asset_path('/css/application.css') %>">
    <% if @refresh_seconds %>
      <meta http-equiv="refresh" content="<%= h @refresh_seconds %>">
    <% end %>
    <title><%= h @title %></title>
    <script type="application/ld+json">
      <%= structured_data %>
    </script>
    <script defer src="<%= h asset_path('/js/navigation.js') %>"></script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href="<%= h app_path('/latest') %>"><img src="/icons/polish-open-source.png">Polish Open Source</a>
        <nav class="nav" aria-label="<%= h t('nav.locations') %>">
          <a class="nav__link" href="<%= h app_path(scope_path(scopes.first)) %>"><%= h t('nav.country') %></a>
          <% primary_city_scopes.each do |scope| %>
            <a class="nav__link" href="<%= h app_path(scope_path(scope)) %>"><%= h scope.fetch(:name) %></a>
          <% end %>
          <details class="nav-menu">
            <summary><%= h t('nav.more_cities') %></summary>
            <div class="nav-menu__panel">
              <% secondary_city_scopes.each do |scope| %>
                <a class="nav__link" href="<%= h app_path(scope_path(scope)) %>"><%= h scope.fetch(:name) %></a>
              <% end %>
            </div>
          </details>
          <a class="nav__link" href="<%= h app_path(editions_path) %>"><%= h t('nav.editions') %></a>
          <a class="nav__link" href="<%= h app_path('/about') %>"><%= h t('nav.about') %></a>
          <% if current_user %>
            <a class="nav__link" href="<%= h app_path(user_profile_path(current_user)) %>">@<%= h current_user.fetch(:login) %></a>
            <form class="nav-form" method="post" action="<%= h app_path('/logout') %>">
              <button class="nav-pill" type="submit"><%= h t('auth.logout') %></button>
            </form>
          <% else %>
            <a class="nav-pill" href="<%= h app_path('/auth/github') %>"><%= h t('auth.login.github') %></a>
          <% end %>
          <div class="language-switch" aria-label="<%= h t('nav.language') %>">
            <% SUPPORTED_LOCALES.each do |locale| %>
              <a class="language-switch__link <%= 'is-active' if current_locale?(locale) %>" href="<%= h locale_path(locale) %>" hreflang="<%= h locale %>" lang="<%= h locale %>"><%= h locale.upcase %></a>
            <% end %>
          </div>
        </nav>
      </div>
    </header>

    <main>
      <%= yield %>
    </main>

    <footer class="site-footer">
      <p><%= h t('footer.data_source') %></p>
    </footer>
  </body>
</html>
