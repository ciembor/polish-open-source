<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="index,follow">
    <meta name="description" content="<%= h @description %>">
    <link rel="canonical" href="<%= h canonical_url %>">
    <link rel="stylesheet" href="/css/application.css">
    <title><%= h @title %></title>
    <script type="application/ld+json">
      <%= structured_data %>
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href="/">Polish GitHub Rank</a>
        <nav class="nav" aria-label="Rankingi lokalizacji">
          <% scopes.each do |scope| %>
            <% href = scope.fetch(:slug) == "poland" ? "/" : city_path(scope.fetch(:slug)) %>
            <a class="nav__link" href="<%= h href %>"><%= h scope.fetch(:name) %></a>
          <% end %>
        </nav>
      </div>
    </header>

    <main>
      <%= yield %>
    </main>

    <footer class="site-footer">
      <p>Dane pochodzą z publicznego API GitHuba i są odświeżane miesięcznie.</p>
    </footer>
  </body>
</html>

