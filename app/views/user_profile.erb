<%= erb :profile_subject_hero, locals: { record: @profile, translation_scope: 'users', translation_value_key: :user } %>

<% top_repository = @repositories.first %>
<section class="profile-section profile-section--compact" aria-labelledby="profile-spotlight-heading">
  <div class="content">
    <article class="profile-spotlight">
      <div class="profile-spotlight__header">
        <h2 id="profile-spotlight-heading"><%= h t('users.spotlight.title') %></h2>
        <% if @profile[:period_start] %>
          <p class="period"><%= h t('rankings.snapshot') %> <time datetime="<%= h @profile[:period_start] %>"><%= h period_label(@profile[:period_start]) %></time></p>
        <% end %>
      </div>

      <dl class="profile-spotlight__grid">
        <div class="profile-spotlight__item">
          <dt><%= h t('users.spotlight.country_rank') %></dt>
          <dd><%= h(@profile[:elite_rank] ? "##{@profile[:elite_rank]}" : '-') %></dd>
        </div>

        <% if @profile[:city] %>
          <div class="profile-spotlight__item">
            <dt><%= h t('users.spotlight.city_rank', city: @profile.fetch(:city)) %></dt>
            <dd><%= h(@profile[:city_rank] ? "##{@profile[:city_rank]}" : '-') %></dd>
          </div>
        <% end %>

        <% if top_repository %>
          <div class="profile-spotlight__item profile-spotlight__item--repository">
            <dt><%= h t('users.spotlight.top_repository') %></dt>
            <dd>
              <a class="primary-link" href="<%= h app_path(repository_profile_path(top_repository)) %>"><%= h top_repository.fetch(:full_name) %></a>
              <span class="profile-spotlight__meta">⭐ <%= number(top_repository.fetch(:stargazers_count)) %></span>
            </dd>
          </div>
        <% end %>
      </dl>
    </article>
  </div>
</section>

<% if @discord_panel %>
  <section class="profile-section" aria-labelledby="profile-discord-heading">
    <div class="content">
      <article class="profile-summary discord-panel">
        <h2 id="profile-discord-heading"><%= h t('users.discord.title') %></h2>
        <% if @discord_panel[:connection] %>
          <p><%= h t('users.discord.connected', user: @discord_panel.fetch(:connection).fetch(:discord_username)) %></p>
        <% end %>
        <% if @discord_error %>
          <p class="profile-empty"><%= h t("users.discord.errors.#{@discord_error}") %></p>
        <% end %>
        <div class="discord-panel__join">
          <a class="discord-join-button" href="<%= h app_path('/auth/discord') %>"><%= h t('users.discord.connect_action') %></a>
        </div>

        <div class="discord-access">
          <h3><%= h t('users.discord.channels_title') %></h3>
          <ul>
            <% @discord_panel.fetch(:access_channels).each do |channel| %>
              <li><%= h channel %></li>
            <% end %>
          </ul>
        </div>
      </article>
    </div>
  </section>
<% end %>

<% if @show_profile_badges %>
  <section class="profile-section profile-section--alt" aria-labelledby="profile-badge-heading">
    <div class="content">
      <h2 id="profile-badge-heading"><%= h t('users.badge.title') %></h2>
      <% if @profile.fetch(:badges, []).any? %>
        <%= erb :badge_preview, locals: { label: @profile.fetch(:login), badge_path: user_badge_path(@profile), alt_text: t('users.badge.alt') } %>
      <% end %>
      <% @repositories.select { |repository| repository[:polish_repo_badge] && repository[:polish_repo_badge][:value] }.each do |repository| %>
        <%= erb :badge_preview, locals: { label: repository.fetch(:full_name), badge_path: repository_badge_path(repository), alt_text: t('repositories.badge.alt') } %>
      <% end %>
    </div>
  </section>
<% end %>

<section class="profile-section" aria-labelledby="profile-summary-heading">
  <div class="content profile-grid">
    <article class="profile-summary">
      <h2 id="profile-summary-heading"><%= h t('users.summary.title') %></h2>
      <dl class="profile-facts">
        <div>
          <dt><%= h t('users.summary.location') %></dt>
          <dd><%= h(@profile[:location_raw] || @profile[:city] || @profile[:country] || t('users.summary.unknown')) %></dd>
        </div>
        <div>
          <dt><%= h t('users.summary.city') %></dt>
          <dd><%= h(@profile[:city] || t('users.summary.unknown')) %></dd>
        </div>
        <div>
          <dt><%= h t('users.summary.public_repositories') %></dt>
          <dd><%= number(@profile[:public_repo_count]) %></dd>
        </div>
      </dl>
    </article>

    <article class="profile-summary">
      <h2><%= h t('users.metrics.title') %></h2>
      <% if @profile[:period_start] %>
        <p class="period"><%= h t('rankings.snapshot') %> <time datetime="<%= h @profile[:period_start] %>"><%= h period_label(@profile[:period_start]) %></time></p>
      <% else %>
        <p class="profile-empty"><%= h t('users.metrics.outside_ranking') %></p>
      <% end %>
      <dl class="profile-metrics">
        <% if !@profile[:total_stars].nil? %>
          <div>
            <dt><%= h t('rankings.metric.stars') %></dt>
            <dd>⭐ <%= number(@profile[:total_stars]) %></dd>
          </div>
        <% end %>
        <% if !@profile[:monthly_stars_delta].nil? %>
          <div>
            <dt><%= h t('rankings.metric.new_stars') %></dt>
            <dd>⭐ <%= number(@profile[:monthly_stars_delta]) %></dd>
          </div>
        <% end %>
        <% if !@profile[:public_activity_count].nil? %>
          <div>
            <dt><%= h t('rankings.metric.events') %></dt>
            <dd><%= number(@profile[:public_activity_count]) %></dd>
          </div>
        <% end %>
        <% if @show_profile_badges %>
          <% @profile.fetch(:badges, []).each do |badge| %>
            <div>
              <dt><%= h badge.fetch(:label) %></dt>
              <dd><%= h(badge[:value] || t('users.metrics.outside_ranking')) %></dd>
            </div>
          <% end %>
        <% end %>
      </dl>
    </article>
  </div>
</section>

<section class="profile-section profile-section--alt" aria-labelledby="profile-repositories-heading">
  <div class="content">
    <h2 id="profile-repositories-heading"><%= h t('users.repositories.title') %></h2>
    <%= erb :profile_repository_grid, locals: {
      repositories: @repositories,
      empty_translation_key: 'users.repositories.empty',
      path_builder: method(:repository_profile_path),
      show_homepage: true
    } %>
  </div>
</section>
