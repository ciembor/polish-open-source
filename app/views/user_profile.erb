<section class="profile-hero">
  <div class="content profile-hero__inner">
    <p class="eyebrow"><%= h platform_name(@profile.fetch(:platform)) %></p>
    <div class="profile-identity">
      <% if @profile[:avatar_url] && !@profile[:avatar_url].empty? %>
        <img class="profile-avatar" src="<%= h @profile[:avatar_url] %>" alt="<%= h t('users.avatar_alt', user: @profile.fetch(:login)) %>">
      <% else %>
        <div class="profile-avatar profile-avatar--fallback" aria-hidden="true"><%= h @profile.fetch(:login)[0].upcase %></div>
      <% end %>
      <div>
        <div class="profile-title-row">
          <h1><%= h(@profile[:name].to_s.empty? ? @profile.fetch(:login) : @profile[:name]) %></h1>
          <%= erb :elite_medal, locals: { rank: @profile[:elite_rank], size: "large" } %>
        </div>
        <p class="profile-login">@<%= h @profile.fetch(:login) %></p>
        <div class="profile-actions">
          <a class="ranking-action" href="<%= h @profile.fetch(:html_url) %>"><%= h t('users.links.source_profile', platform: platform_name(@profile.fetch(:platform))) %></a>
          <% if @profile[:homepage] && !@profile[:homepage].empty? %>
            <a class="ranking-action" href="<%= h @profile[:homepage] %>"><%= h t('users.links.homepage') %></a>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<% if @discord_panel %>
  <section class="profile-section" aria-labelledby="profile-discord-heading">
    <div class="content">
      <article class="profile-summary discord-panel">
        <h2 id="profile-discord-heading"><%= h t('users.discord.title') %></h2>
        <% if @discord_panel[:connection] %>
          <p><%= h t('users.discord.connected', user: @discord_panel.fetch(:connection).fetch(:discord_username)) %></p>
        <% end %>
        <% if @discord_error %>
          <p class="profile-empty"><%= h t("users.discord.errors.#{@discord_error}") %></p>
        <% end %>
        <div class="discord-panel__join">
          <a class="discord-join-button" href="<%= h app_path('/auth/discord') %>"><%= h t('users.discord.connect_action') %></a>
        </div>

        <dl class="profile-facts discord-panel__facts">
          <% access = @discord_panel.fetch(:access) %>
          <div>
            <dt><%= h t('users.discord.poland_rank') %></dt>
            <dd><%= access[:country_rank] ? h("##{access.fetch(:country_rank)}") : h(t('users.summary.unknown')) %></dd>
          </div>
          <% if access[:city] %>
            <div>
              <dt><%= h t('users.discord.city_rank', city: access.fetch(:city)) %></dt>
              <dd><%= access[:city_rank] ? h("##{access.fetch(:city_rank)}") : h(t('users.summary.unknown')) %></dd>
            </div>
          <% end %>
        </dl>
        <div class="discord-access">
          <h3><%= h t('users.discord.channels_title') %></h3>
          <% if @discord_panel.fetch(:access_channels).empty? %>
            <p class="profile-empty"><%= h t('users.discord.no_channels') %></p>
          <% else %>
            <ul>
              <% @discord_panel.fetch(:access_channels).each do |channel| %>
                <li><%= h channel %></li>
              <% end %>
            </ul>
          <% end %>
        </div>
      </article>
    </div>
  </section>
<% end %>

<% if @show_profile_badges %>
  <section class="profile-section profile-section--alt" aria-labelledby="profile-badge-heading">
    <div class="content">
      <h2 id="profile-badge-heading"><%= h t('users.badge.title') %></h2>
      <% if @profile.fetch(:badges, []).any? %>
        <div class="badge-preview">
          <p class="badge-preview__label"><%= h @profile.fetch(:login) %></p>
          <a href="<%= h app_path('/latest') %>">
            <img src="<%= h app_path(user_badge_path(@profile)) %>" alt="<%= h t('users.badge.alt') %>">
          </a>
          <code><%= h linked_badge_markdown(t('users.badge.alt'), user_badge_path(@profile)) %></code>
        </div>
      <% end %>
      <% @repositories.select { |repository| repository[:polish_repo_badge] && repository[:polish_repo_badge][:value] }.each do |repository| %>
        <div class="badge-preview">
          <p class="badge-preview__label"><%= h repository.fetch(:full_name) %></p>
          <a href="<%= h app_path('/latest') %>">
            <img src="<%= h app_path(repository_badge_path(repository)) %>" alt="<%= h t('repositories.badge.alt') %>">
          </a>
          <code><%= h linked_badge_markdown(t('repositories.badge.alt'), repository_badge_path(repository)) %></code>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

<section class="profile-section" aria-labelledby="profile-summary-heading">
  <div class="content profile-grid">
    <article class="profile-summary">
      <h2 id="profile-summary-heading"><%= h t('users.summary.title') %></h2>
      <dl class="profile-facts">
        <div>
          <dt><%= h t('users.summary.location') %></dt>
          <dd><%= h(@profile[:location_raw] || @profile[:city] || @profile[:country] || t('users.summary.unknown')) %></dd>
        </div>
        <div>
          <dt><%= h t('users.summary.city') %></dt>
          <dd><%= h(@profile[:city] || t('users.summary.unknown')) %></dd>
        </div>
        <div>
          <dt><%= h t('users.summary.public_repositories') %></dt>
          <dd><%= number(@profile[:public_repo_count]) %></dd>
        </div>
      </dl>
    </article>

    <article class="profile-summary">
      <h2><%= h t('users.metrics.title') %></h2>
      <% if @profile[:period_start] %>
        <p class="period"><%= h t('rankings.snapshot') %> <time datetime="<%= h @profile[:period_start] %>"><%= h @profile[:period_start] %></time></p>
      <% end %>
      <dl class="profile-metrics">
        <div>
          <dt><%= h t('rankings.metric.stars') %></dt>
          <dd>⭐ <%= number(@profile[:total_stars]) %></dd>
        </div>
        <div>
          <dt><%= h t('rankings.metric.new_stars') %></dt>
          <dd>⭐ <%= number(@profile[:monthly_stars_delta]) %></dd>
        </div>
        <div>
          <dt><%= h t('rankings.metric.events') %></dt>
          <dd><%= number(@profile[:public_activity_count]) %></dd>
        </div>
        <% if @show_profile_badges %>
          <% @profile.fetch(:badges, []).each do |badge| %>
            <div>
              <dt><%= h badge.fetch(:label) %></dt>
              <dd><%= h badge.fetch(:value) %></dd>
            </div>
          <% end %>
        <% end %>
      </dl>
    </article>
  </div>
</section>

<section class="profile-section profile-section--alt" aria-labelledby="profile-repositories-heading">
  <div class="content">
    <h2 id="profile-repositories-heading"><%= h t('users.repositories.title') %></h2>
    <% if @repositories.empty? %>
      <p class="profile-empty"><%= h t('users.repositories.empty') %></p>
    <% else %>
      <div class="project-grid">
        <% @repositories.each do |repository| %>
          <article class="project-card">
            <div class="project-card__header">
              <%= erb :platform_icon, locals: { platform: repository.fetch(:platform, "github") } %>
              <a class="primary-link" href="<%= h app_path(repository_profile_path(repository)) %>"><%= h repository.fetch(:full_name) %></a>
            </div>
            <% if repository[:description] && !repository[:description].empty? %>
              <p><%= h repository[:description] %></p>
            <% end %>
            <dl class="project-stats">
              <div>
                <dt><%= h t('rankings.metric.stars') %></dt>
                <dd>⭐ <%= number(repository.fetch(:stargazers_count)) %></dd>
              </div>
              <div>
                <dt><%= h t('rankings.metric.new_stars') %></dt>
                <dd>⭐ <%= number(repository.fetch(:monthly_stars_delta)) %></dd>
              </div>
              <% if repository[:language] && !repository[:language].empty? %>
                <div>
                  <dt><%= h t('users.repositories.language') %></dt>
                  <dd><%= h repository[:language] %></dd>
                </div>
              <% end %>
            </dl>
            <% if repository[:homepage] && !repository[:homepage].empty? %>
              <a class="muted-link muted-link--standalone" href="<%= h repository[:homepage] %>"><%= h t('users.links.homepage') %></a>
            <% end %>
          </article>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
