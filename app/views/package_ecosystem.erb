<section class="hero">
  <div class="hero__inner">
    <div>
      <p class="eyebrow"><%= h t('packages.hero.eyebrow') %></p>
      <h1><%= h t('packages.ecosystem.title', ecosystem: @package_ecosystem) %></h1>
      <p class="lede"><%= h t('packages.ecosystem.lede') %></p>
      <% if @period %>
        <p class="period"><%= h t('rankings.snapshot') %> <time datetime="<%= h @period %>"><%= h period_label(@period) %></time></p>
      <% end %>
    </div>
    <img class="hero__image" src="/images/polish_open_source_front.webp" alt="" aria-hidden="true">
  </div>
</section>

<section class="ranking-band">
  <div class="content">
    <p><a class="muted-link muted-link--standalone" href="<%= h app_path(package_index_path) %>"><%= h t('packages.back') %></a></p>
    <div class="ranking-grid ranking-grid--compact">
      <% PolishOpenSourceRank::Contexts::Packages::Domain::PackageRankingMetric.all(ecosystem: @package_ecosystem).each do |package_metric| %>
        <% slug = package_metric.slug %>
        <% metric = package_metric.key.to_sym %>
        <%= erb :package_ranking_table, locals: { heading_id: "package-ranking-#{slug}", title: t("packages.ranking_title.#{slug}"), rows: @package_rankings.fetch(metric, []), metric: metric, metric_label: package_metric_label(metric), top_path: package_ranking_path(@package_ecosystem, slug) } %>
      <% end %>
    </div>
  </div>
</section>
