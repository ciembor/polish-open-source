<article class="ranking-table">
  <h3><%= h title %></h3>
  <table>
    <thead>
      <tr>
        <th scope="col">#</th>
        <th scope="col"><%= h t('rankings.table.user') %></th>
        <th scope="col"><%= h t('rankings.table.city') %></th>
        <th scope="col"><%= h metric_label %></th>
      </tr>
    </thead>
    <tbody>
      <% rows.each_with_index do |row, index| %>
        <tr>
          <td><%= index + 1 %></td>
          <td>
            <%= erb :platform_icon, locals: { platform: row.fetch(:platform, "github") } %>
            <a class="primary-link" href="<%= h app_path(user_profile_path(row)) %>"><%= h row.fetch(:login) %></a>
            <% if row[:name] && !row[:name].empty? %>
              <span><%= h row[:name] %></span>
            <% end %>
            <a class="muted-link" href="<%= h row.fetch(:html_url) %>"><%= h platform_name(row.fetch(:platform, "github")) %></a>
            <% if row[:homepage] && !row[:homepage].empty? %>
              <a class="muted-link" href="<%= h row[:homepage] %>">www</a>
            <% end %>
          </td>
          <td><%= h(row[:city] || t('scope.poland')) %></td>
          <td class="metric"><%= number(row.fetch(metric)) %></td>
        </tr>
      <% end %>
      <% if rows.empty? %>
        <tr>
          <td colspan="4"><%= h t('rankings.empty.records') %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if defined?(top_path) && top_path %>
    <a class="ranking-action" href="<%= h app_path(top_path) %>"><%= h t('rankings.see_top_100') %></a>
  <% end %>
</article>
