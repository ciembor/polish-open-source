<article class="profile-summary profile-access-card discord-panel">
  <h2 id="profile-discord-heading"><%= h t('users.discord.title') %></h2>
  <div class="profile-access-card__body discord-panel__body">
    <% if error %>
      <p class="profile-empty"><%= h t("users.discord.errors.#{error}") %></p>
    <% end %>
    <div class="discord-panel__join">
      <a class="discord-join-button" href="<%= h app_path('/auth/discord') %>"><%= h t('users.discord.connect_action') %></a>
    </div>
    <% if panel[:connection] %>
      <p class="discord-panel__status"><%= h t('users.discord.connected', user: panel.fetch(:connection).fetch(:discord_username)) %></p>
      <% if panel[:sync_status] && panel[:sync_status] != 'synced' %>
        <p class="profile-empty"><%= h t("users.discord.sync_status.#{panel[:sync_status]}") %></p>
      <% end %>
    <% else %>
      <p class="discord-panel__status"><%= h t('users.discord.connect_body') %></p>
    <% end %>
    <div class="discord-access">
      <h3><%= h t('users.discord.groups_title') %></h3>
      <% if panel.fetch(:access_groups).any? %>
        <ul>
          <% panel.fetch(:access_groups).each do |group| %>
            <li><%= h group %></li>
          <% end %>
        </ul>
      <% else %>
        <p class="profile-empty"><%= h t('users.discord.no_groups') %></p>
      <% end %>
    </div>
  </div>
</article>
