<section class="hero">
  <div class="hero__inner">
    <div>
      <p class="eyebrow">Dev</p>
      <h1>Login</h1>
      <p class="lede">Pick a ranked GitHub user to impersonate.</p>
    </div>
  </div>
</section>

<%= erb :"shared/location_notice" %>

<section class="ranking-band">
  <div class="content">
    <form method="get" action="<%= h app_path('/auth/dev/user') %>" class="nav-form" style="margin-bottom: 18px;">
      <label for="dev-login" style="display:block;font-weight:700;margin-bottom:8px;">GitHub login</label>
      <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
        <input id="dev-login" name="login" type="text" style="max-width: 320px; width: 100%; padding: 10px 12px; border: 1px solid var(--line); border-radius: 6px;">
        <button class="nav-pill" type="submit">Login</button>
      </div>
    </form>

    <% if @users.empty? %>
      <p class="lede">No ranked users found. Seed demo data with <code>ruby scripts/dev_seed.rb</code>.</p>
    <% else %>
      <ol style="columns: 2; column-gap: 32px; padding-left: 18px; margin: 0;">
        <% @users.each do |row| %>
          <li>
            <a class="primary-link" href="<%= h app_path("/auth/dev/#{row.fetch(:login)}") %>">@<%= h row.fetch(:login) %></a>
          </li>
        <% end %>
      </ol>
    <% end %>
  </div>
</section>
