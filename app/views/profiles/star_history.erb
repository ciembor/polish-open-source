<% chart_url = star_history_chart_url(record) %>
<% page_url = star_history_page_url(record) %>

<% if chart_url && page_url %>
  <section class="profile-section profile-section--alt profile-star-history" aria-labelledby="<%= h heading_id %>">
    <div class="content">
      <div class="profile-section__heading-row">
        <h2 id="<%= h heading_id %>"><%= h t('repositories.star_history.title') %></h2>
        <a class="profile-action profile-action--inline" href="<%= h page_url %>">Star History</a>
      </div>
      <article class="profile-star-history__panel">
        <img
          class="profile-star-history__chart"
          src="<%= h chart_url %>"
          alt="<%= h t('repositories.star_history.alt', repository: record.fetch(:full_name)) %>"
          width="1200"
          height="600"
          loading="lazy"
          decoding="async">
      </article>
    </div>
  </section>
<% end %>
