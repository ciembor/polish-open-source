<%= erb :"profiles/subject_hero", locals: { record: @organization, translation_scope: 'organizations', translation_value_key: :organization } %>

<% top_repository = @repositories.first %>
<% spotlight_items = [
  { label: t('organizations.spotlight.country_rank'), value: (@organization[:elite_rank] ? "##{@organization[:elite_rank]}" : '-') }
] %>
<% if @organization[:city] %>
  <% spotlight_items << { label: t('organizations.spotlight.city_rank', city: @organization.fetch(:city)), value: (@organization[:city_rank] ? "##{@organization[:city_rank]}" : '-') } %>
<% end %>
<%= erb :"profiles/spotlight", locals: {
  heading_id: 'organization-spotlight-heading',
  title: t('organizations.spotlight.title'),
  period_start: @organization[:period_start],
  items: spotlight_items,
  top_repository: top_repository,
  top_repository_label: t('organizations.spotlight.top_repository'),
  top_repository_path: top_repository ? organization_repository_profile_path(top_repository) : nil
} %>

<section class="profile-section profile-section--alt" aria-labelledby="organization-badge-heading">
  <div class="content">
    <h2 id="organization-badge-heading"><%= h t('organizations.badge.title') %></h2>
    <%= erb :"profiles/inline_badge_preview", locals: { badge_path: organization_badge_path(@organization), alt_text: t('organizations.badge.alt') } %>
  </div>
</section>

<section class="profile-section" aria-labelledby="organization-summary-heading">
  <div class="content profile-grid">
    <%= erb :"profiles/fact_card", locals: {
      heading_id: 'organization-summary-heading',
      title: t('organizations.summary.title'),
      items: [
        { label: t('organizations.summary.location'), value: (@organization[:location_raw] || @organization[:city] || @organization[:country] || t('users.summary.unknown')) },
        { label: t('users.summary.city'), value: (@organization[:city] || t('users.summary.unknown')) },
        { label: t('organizations.summary.public_repositories'), value: number(@organization[:public_repo_count]) }
      ]
    } %>

    <% metric_items = [] %>
    <% metric_items << { label: t('rankings.metric.stars'), value: "⭐ #{number(@organization[:total_stars])}" } unless @organization[:total_stars].nil? %>
    <% metric_items << { label: t('rankings.metric.new_stars'), value: "⭐ #{number(@organization[:monthly_stars_delta])}" } unless @organization[:monthly_stars_delta].nil? %>
    <% metric_items << { label: @organization.fetch(:profile_badge).fetch(:label), value: (@organization.fetch(:profile_badge)[:value] || t('users.metrics.outside_ranking')) } %>
    <%= erb :"profiles/metric_card", locals: {
      title: t('users.metrics.title'),
      period_start: @organization[:period_start],
      empty_message: t('users.metrics.outside_ranking'),
      items: metric_items
    } %>
  </div>
</section>

<section class="profile-section profile-section--alt" aria-labelledby="organization-repositories-heading">
  <div class="content">
    <h2 id="organization-repositories-heading"><%= h t('organizations.repositories.title') %></h2>
    <div class="organization-repository-columns">
      <section class="organization-repository-column" aria-labelledby="organization-top-repositories-heading">
        <h3 id="organization-top-repositories-heading"><%= h t('organizations.repositories.top_title') %></h3>
        <%= erb :"profiles/repository_grid", locals: {
          repositories: @repositories,
          empty_translation_key: 'organizations.repositories.empty',
          path_builder: method(:organization_repository_profile_path),
          show_homepage: false,
          grid_class: 'project-grid project-grid--stacked'
        } %>
      </section>
      <section class="organization-repository-column" aria-labelledby="organization-popular-repositories-heading">
        <h3 id="organization-popular-repositories-heading"><%= h t('organizations.repositories.popular_title') %></h3>
        <%= erb :"profiles/repository_grid", locals: {
          repositories: @popular_repositories,
          empty_translation_key: 'organizations.repositories.empty',
          path_builder: method(:organization_repository_profile_path),
          show_homepage: false,
          grid_class: 'project-grid project-grid--stacked'
        } %>
      </section>
    </div>
  </div>
</section>
