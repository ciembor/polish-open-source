<article class="profile-summary">
  <h2><%= h title %></h2>
  <% if period_start %>
    <p class="period"><%= h t('rankings.snapshot') %> <time datetime="<%= h period_start %>"><%= h period_label(period_start) %></time></p>
  <% elsif empty_message %>
    <p class="profile-empty"><%= h empty_message %></p>
  <% end %>
  <dl class="profile-metrics">
    <% items.each do |item| %>
      <div>
        <dt><%= h item.fetch(:label) %></dt>
        <dd><%= h item.fetch(:value) %></dd>
      </div>
    <% end %>
  </dl>
</article>
