<%= erb :"profiles/project_hero", locals: { record: @repository } %>

<section class="profile-section" aria-labelledby="repository-summary-heading">
  <div class="content profile-grid">
    <% fact_items = [
      {
        label: t('repositories.summary.owner'),
        value_html: %(<a class="primary-link" href="#{h app_path(user_profile_path(platform: @repository.fetch(:platform), login: @repository.fetch(:owner_login), name: @repository[:owner_name]))}">#{h owner_login_display_name(@repository[:owner_name], @repository.fetch(:owner_login))}</a>)
      },
      { label: t('users.summary.city'), value: (@repository[:owner_city] || t('users.summary.unknown')) }
    ] %>
    <% if @repository[:language] && !@repository[:language].empty? %>
      <% fact_items << { label: t('users.repositories.language'), value: @repository[:language] } %>
    <% end %>
    <%= erb :"profiles/fact_card", locals: {
      heading_id: 'repository-summary-heading',
      title: t('repositories.summary.title'),
      items: fact_items
    } %>

    <% metric_items = [
      { label: t('rankings.metric.stars'), value: "⭐ #{number(@repository[:stargazers_count])}" },
      { label: t('rankings.metric.new_stars'), value: "⭐ #{number(@repository[:monthly_stars_delta])}" }
    ] %>
    <% if @repository[:polish_repo_badge] && @repository[:polish_repo_badge][:value] %>
      <% metric_items << { label: @repository[:polish_repo_badge].fetch(:label), value: @repository[:polish_repo_badge].fetch(:value) } %>
    <% end %>
    <%= erb :"profiles/metric_card", locals: {
      title: t('users.metrics.title'),
      period_start: @repository[:period_start],
      empty_message: nil,
      items: metric_items
    } %>
  </div>
</section>

<%= erb :"profiles/star_history", locals: { record: @repository, heading_id: 'repository-star-history-heading' } %>

<% if @repository[:polish_repo_badge] && @repository[:polish_repo_badge][:value] %>
  <section class="profile-section profile-section--alt" aria-labelledby="repository-badge-heading">
    <div class="content">
      <h2 id="repository-badge-heading"><%= h t('repositories.badge.title') %></h2>
      <%= erb :"profiles/inline_badge_preview", locals: { badge_path: repository_badge_path(@repository), alt_text: t('repositories.badge.alt') } %>
    </div>
  </section>
<% end %>
