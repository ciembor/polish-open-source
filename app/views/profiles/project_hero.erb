<section class="profile-hero">
  <div class="content profile-hero__inner">
    <p class="eyebrow"><%= h platform_name(record.fetch(:platform)) %></p>
    <div class="profile-identity profile-identity--project">
      <div class="project-avatar" aria-hidden="true">
        <%= erb :"shared/platform_icon", locals: { platform: record.fetch(:platform, "github") } %>
      </div>
      <div>
        <div class="profile-title-row">
          <h1><%= h record.fetch(:full_name) %></h1>
          <%= erb :"shared/elite_medal", locals: { rank: record[:elite_rank], size: "large" } %>
        </div>
        <% if record[:description] && !record[:description].empty? %>
          <p class="lede"><%= h record[:description] %></p>
        <% end %>
        <div class="profile-actions">
          <% source_url = safe_external_url(record[:html_url]) %>
          <% homepage_url = safe_external_url(record[:homepage]) %>
          <% if source_url %>
            <a class="profile-action" href="<%= h source_url %>"><%= h t('repositories.links.source_project', platform: platform_name(record.fetch(:platform))) %></a>
          <% end %>
          <% if homepage_url %>
            <a class="profile-action" href="<%= h homepage_url %>"><%= h t('users.links.homepage') %></a>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<%= erb :"shared/location_notice" %>
