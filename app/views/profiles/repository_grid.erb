<% if repositories.empty? %>
  <p class="profile-empty"><%= h t(empty_translation_key) %></p>
<% else %>
  <div class="<%= h(defined?(grid_class) ? grid_class : 'project-grid') %>">
    <% repositories.each do |repository| %>
      <article class="project-card">
        <div class="project-card__header">
          <%= erb :"shared/platform_icon", locals: { platform: repository.fetch(:platform, "github") } %>
          <a class="primary-link" href="<%= h app_path(path_builder.call(repository)) %>"><%= h repository_display_name(repository) %></a>
        </div>
        <% if repository[:description] && !repository[:description].empty? %>
          <p><%= h repository[:description] %></p>
        <% end %>
        <dl class="project-stats">
          <div>
            <dt><%= h t('rankings.metric.stars') %></dt>
            <dd>⭐ <%= number(repository.fetch(:stargazers_count)) %></dd>
          </div>
          <div>
            <dt><%= h t('rankings.metric.new_stars') %></dt>
            <dd>⭐ <%= number(repository.fetch(:monthly_stars_delta)) %></dd>
          </div>
          <% if repository[:language] && !repository[:language].empty? %>
            <div>
              <dt><%= h t('users.repositories.language') %></dt>
              <dd><%= h repository[:language] %></dd>
            </div>
          <% end %>
        </dl>
        <% homepage_url = safe_external_url(repository[:homepage]) %>
        <% if show_homepage && homepage_url %>
          <a class="muted-link muted-link--standalone" href="<%= h homepage_url %>"><%= h t('users.links.homepage') %></a>
        <% end %>
      </article>
    <% end %>
  </div>
<% end %>
