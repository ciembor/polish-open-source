<%= erb :"profiles/subject_hero", locals: { record: @profile, translation_scope: 'users', translation_value_key: :user } %>

<% if @profile[:profile_deleted] == 1 %>
  <section class="profile-section profile-section--compact" aria-labelledby="profile-deleted-heading">
    <div class="content profile-deleted">
      <h2 id="profile-deleted-heading"><%= h t('users.deleted.title') %></h2>
      <p><%= h t('users.deleted.body') %></p>
    </div>
  </section>
<% else %>
<% top_repository = @repositories.first %>
<% spotlight_items = [
  { label: t('users.spotlight.country_rank'), value: (@profile[:elite_rank] ? "##{@profile[:elite_rank]}" : '-') }
] %>
<% if @profile[:city] %>
  <% spotlight_items << { label: t('users.spotlight.city_rank', city: @profile.fetch(:city)), value: (@profile[:city_rank] ? "##{@profile[:city_rank]}" : '-') } %>
<% end %>
<%= erb :"profiles/spotlight", locals: {
  heading_id: 'profile-spotlight-heading',
  title: t('users.spotlight.title'),
  period_start: @profile[:period_start],
  items: spotlight_items,
  top_repository: top_repository,
  top_repository_label: t('users.spotlight.top_repository'),
  top_repository_path: top_repository ? repository_profile_path(top_repository) : nil
} %>

<% profile_badge_visible = @show_profile_badges && @profile.fetch(:badges, []).any? %>
<% if @discord_panel || profile_badge_visible %>
  <section class="profile-section" aria-label="<%= h t('users.profile_access.title') %>">
    <div class="content profile-access-grid">
      <% if @discord_panel %>
        <%= erb :"auth/discord_panel", locals: { panel: @discord_panel, error: @discord_error } %>
      <% end %>
      <% if profile_badge_visible %>
        <article class="profile-summary profile-access-card profile-badge-panel">
          <h2 id="profile-badge-heading"><%= h t('users.badge.title') %></h2>
          <div class="profile-access-card__body">
            <%= erb :"profiles/badge_preview", locals: { label: @profile.fetch(:login), badge_path: user_badge_path(@profile), alt_text: t('users.badge.alt'), variant: 'badge-preview--profile' } %>
          </div>
        </article>
      <% end %>
    </div>
  </section>
<% end %>

<section class="profile-section" aria-labelledby="profile-summary-heading">
  <div class="content profile-grid">
    <%= erb :"profiles/fact_card", locals: {
      heading_id: 'profile-summary-heading',
      title: t('users.summary.title'),
      items: [
        { label: t('users.summary.location'), value: (@profile[:location_raw] || @profile[:city] || @profile[:country] || t('users.summary.unknown')) },
        { label: t('users.summary.city'), value: (@profile[:city] || t('users.summary.unknown')) },
        { label: t('users.summary.public_repositories'), value: number(@profile[:public_repo_count]) }
      ]
    } %>

    <% metric_items = [] %>
    <% metric_items << { label: t('rankings.metric.stars'), value: "⭐ #{number(@profile[:total_stars])}" } unless @profile[:total_stars].nil? %>
    <% metric_items << { label: t('rankings.metric.new_stars'), value: "⭐ #{number(@profile[:monthly_stars_delta])}" } unless @profile[:monthly_stars_delta].nil? %>
    <% if @show_profile_badges %>
      <% @profile.fetch(:badges, []).each do |badge| %>
        <% metric_items << { label: badge.fetch(:label), value: (badge[:value] || t('users.metrics.outside_ranking')) } %>
      <% end %>
    <% end %>
    <%= erb :"profiles/metric_card", locals: {
      title: t('users.metrics.title'),
      period_start: @profile[:period_start],
      empty_message: t('users.metrics.outside_ranking'),
      items: metric_items
    } %>
  </div>
</section>

<section class="profile-section profile-section--alt" aria-labelledby="profile-repositories-heading">
  <div class="content">
    <h2 id="profile-repositories-heading"><%= h t('users.repositories.title') %></h2>
    <%= erb :"profiles/repository_grid", locals: {
      repositories: @repositories,
      empty_translation_key: 'users.repositories.empty',
      path_builder: method(:repository_profile_path),
      badge_path_builder: (@show_profile_badges ? method(:repository_badge_path) : nil),
      badge_alt_text: t('repositories.badge.alt'),
      show_homepage: true
    } %>
  </div>
</section>

<% if @show_profile_delete_control %>
  <section class="profile-section profile-delete-section" aria-labelledby="profile-delete-heading">
    <div class="content profile-delete">
      <h2 id="profile-delete-heading" class="visually-hidden"><%= h t('users.delete.title') %></h2>
      <p>
        <%= h t('users.delete.prompt_prefix') %>
        <button class="profile-delete__link js-profile-delete-open" type="button" data-target="#profile-delete-modal"><%= h t('users.delete.link') %></button>.
      </p>
      <div id="profile-delete-modal" class="profile-delete-modal js-profile-delete-modal" role="dialog" aria-modal="true" aria-labelledby="profile-delete-modal-heading" hidden>
        <div class="profile-delete-modal__panel">
          <p id="profile-delete-modal-heading"><%= h t('users.delete.confirm') %></p>
          <form class="profile-delete-modal__actions" method="post" action="<%= h app_path("#{user_profile_path(@profile)}/delete") %>">
            <input type="hidden" name="csrf_token" value="<%= h csrf_token %>">
            <button class="profile-delete-modal__confirm" type="submit"><%= h t('users.delete.confirm_yes') %></button>
            <button class="profile-delete-modal__cancel js-profile-delete-cancel" type="button"><%= h t('users.delete.confirm_no') %></button>
          </form>
        </div>
      </div>
    </div>
  </section>
<% end %>
<% end %>
